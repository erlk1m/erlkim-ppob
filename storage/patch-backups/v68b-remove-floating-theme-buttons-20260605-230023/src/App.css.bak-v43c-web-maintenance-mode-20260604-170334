
.qrisBoxReal {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  padding: 16px;
}

.qrisImage {
  width: 100%;
  max-width: 260px;
  height: auto;
  display: block;
  margin: 0 auto;
  border: 3px solid #111827;
  border-radius: 16px;
  background: #fff;
  padding: 12px;
}


.erlkimTestingBadge {
  position: fixed;
  left: 16px;
  right: 16px;
  bottom: 16px;
  z-index: 9999;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 4px 12px;
  align-items: center;
  max-width: 760px;
  margin: 0 auto;
  padding: 12px 14px;
  border: 3px solid #111827;
  border-radius: 16px;
  background: #facc15;
  color: #111827;
  box-shadow: 5px 5px 0 #111827;
  font-size: 13px;
}

.erlkimTestingBadge strong {
  font-size: 14px;
  line-height: 1.1;
}

.erlkimTestingBadge span {
  grid-column: 1 / 2;
  opacity: 0.9;
}

.erlkimTestingBadge button {
  grid-column: 2 / 3;
  grid-row: 1 / 3;
  width: 32px;
  height: 32px;
  border: 2px solid #111827;
  border-radius: 10px;
  background: #fff;
  color: #111827;
  font-weight: 900;
  cursor: pointer;
}

@media (max-width: 640px) {
  .erlkimTestingBadge {
    left: 10px;
    right: 10px;
    bottom: 10px;
    font-size: 12px;
  }
}

/* v41 Store Invoice UI polish */
.invoiceStatusGuide {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 14px;
  align-items: center;
  border: 3px solid #111827;
  border-radius: 18px;
  padding: 14px;
  margin: 14px 0;
  background: #fef3c7;
  box-shadow: 4px 4px 0 #111827;
}

.invoiceStatusGuide.success,
.invoiceStatusGuide.paid.success {
  background: #bbf7d0;
}

.invoiceStatusGuide.processing,
.invoiceStatusGuide.paid.processing {
  background: #bfdbfe;
}

.invoiceStatusGuide.failed,
.invoiceStatusGuide.canceled,
.invoiceStatusGuide.cancelled {
  background: #fecaca;
}

.invoiceStatusGuide h3 {
  margin: 4px 0;
  font-size: 18px;
}

.invoiceStatusGuide p {
  margin: 0;
  font-size: 13px;
  line-height: 1.45;
}

.invoiceStatusPills {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8px;
}

.qrisInstructionBox {
  display: grid;
  gap: 6px;
  border: 3px solid #111827;
  border-radius: 16px;
  background: #fef3c7;
  padding: 12px;
  box-shadow: 3px 3px 0 #111827;
}

.qrisInstructionBox p {
  margin: 0;
  font-size: 13px;
  line-height: 1.45;
}

.qrisInstructionBox small {
  font-weight: 900;
}

.resultCard.successResult {
  border: 3px solid #111827;
  border-radius: 18px;
  background: #bbf7d0;
  box-shadow: 4px 4px 0 #111827;
}

.resultCard.successResult code {
  display: block;
  padding: 12px;
  border: 2px solid #111827;
  border-radius: 12px;
  background: #ffffff;
  word-break: break-word;
  font-size: 16px;
  font-weight: 900;
}

.invoicePaymentPanel .manualPayBox {
  display: grid;
  gap: 12px;
}

.invoicePaymentPanel .qrisBoxReal,
.invoicePaymentPanel .qrisBox {
  max-width: 292px;
  margin: 0 auto;
}

@media (max-width: 720px) {
  .invoiceStatusGuide {
    grid-template-columns: 1fr;
  }

  .invoiceStatusPills {
    justify-content: flex-start;
  }

  .invoicePaymentPanel .qrisBoxReal,
  .invoicePaymentPanel .qrisBox {
    max-width: 100%;
  }
}

/* v42 Store checkout/product polish */
.erlkimStoreCheckoutPolish {
  width: min(1180px, calc(100% - 24px));
  margin: 14px auto;
  border: 3px solid #111827;
  border-radius: 18px;
  background: #fef3c7;
  box-shadow: 5px 5px 0 #111827;
  padding: 14px;
  color: #111827;
}

.erlkimStoreCheckoutPolish strong {
  display: block;
  font-size: 16px;
  margin-bottom: 4px;
}

.erlkimStoreCheckoutPolish p {
  margin: 0;
  font-size: 13px;
  line-height: 1.45;
}

.erlkimStoreCheckoutTips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 10px;
}

.erlkimStoreCheckoutTips span {
  border: 2px solid #111827;
  border-radius: 999px;
  background: #fff;
  padding: 6px 9px;
  box-shadow: 2px 2px 0 #111827;
  font-size: 12px;
  font-weight: 900;
}

@media (max-width: 640px) {
  .erlkimStoreCheckoutPolish {
    width: calc(100% - 20px);
    margin: 10px auto;
    padding: 12px;
  }

  .erlkimStoreCheckoutTips {
    display: grid;
  }
}
