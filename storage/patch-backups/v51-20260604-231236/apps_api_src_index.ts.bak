app.post('/api/admin/maintenance/expire-pending', adminOnly, (_req, res) => {
  const cutoff = Date.now() - 60 * 60 * 1000;
  let expired = 0;
  for (const order of store.data.orders) {
    if (order.paymentStatus === 'unpaid' && new Date(order.createdAt).getTime() < cutoff) {
      order.paymentStatus = 'expired';
      order.orderStatus = 'canceled';
      order.updatedAt = nowIso();
      expired++;
    }
  }
  store.save();
  res.json(ok({ expired }));
});
app.post('/api/admin/maintenance/check-processing', adminOnly, async (_req, res, next) => {
  try {
    const candidates = store.data.orders.filter((o: any) => o.paymentStatus === 'paid' && ['processing', 'need_check'].includes(o.orderStatus)).slice(0, 10);
    const updated = [];
    for (const order of candidates) {
      const result = order.type === 'postpaid'
        ? await digiflazz.postpaidCheckStatus({ buyerSkuCode: order.buyerSkuCode, customerNo: order.customerNo, refId: order.refId })
        : await digiflazz.prepaidCheckStatus({ buyerSkuCode: order.buyerSkuCode, customerNo: order.customerNo, refId: order.refId });
      updated.push(applyProviderResult(order.invoice, result, 'maintenance-check-processing'));
    }
    res.json(ok({ checked: candidates.length, updated }));
  } catch (error) { next(error); }
});

async function syncProducts(_req: express.Request, res: express.Response, next: express.NextFunction) {
  try {
    const [prepaid, postpaid] = await Promise.all([digiflazz.priceList('prepaid'), digiflazz.priceList('postpaid')]);
    const rawMapped = [
      ...digiflazz.mapPriceListToProducts(postpaid, store.data.categories, 'postpaid'),
      ...digiflazz.mapPriceListToProducts(prepaid, store.data.categories, 'prepaid')
    ];

    // Dedupe berdasarkan SKU. Prepaid diletakkan terakhir agar kalau API development
    // mengembalikan SKU yang sama di pricelist pasca, kategori prepaid tetap menang.
    const uniqueBySku = new Map<string, any>();
    for (const item of rawMapped) {
      uniqueBySku.set(String(item.buyerSkuCode).toLowerCase(), item);
    }
    const mapped = Array.from(uniqueBySku.values());

    const previousBySku = new Map(store.data.products.map((p: any) => [String(p.buyerSkuCode).toLowerCase(), p]));
    const localProducts = store.data.products.filter((p: any) => p.provider && p.provider !== 'digiflazz');

    store.data.products = [
      ...localProducts,
      ...mapped.map((item: any) => {
        const existing: any = previousBySku.get(String(item.buyerSkuCode).toLowerCase());
        return {
          ...item,
          id: existing?.id || item.id,
          isPopular: existing?.isPopular ?? item.isPopular,
          isFlashsale: existing?.isFlashsale ?? item.isFlashsale
        };
      })
    ];

    store.save();
    res.json(ok({
      synced: true,
      source: 'digiflazz',
      totalRaw: rawMapped.length,
      totalSynced: mapped.length,
      total: store.data.products.length,
      syncedAt: nowIso()
    }));
  } catch (error) { next(error); }
}

function applyProviderResult(invoice: string, result: any, eventName = 'provider-result') {
  const data = result?.data || result || {};
  const orderStatus = mapProviderStatus(data.status, data.rc);
  const patch: any = {
    orderStatus,
    providerStatus: data.status || orderStatus,
    providerRc: data.rc,
    providerMessage: data.message,
    sn: data.sn,
    rawProviderResponse: data
  };
  if (orderStatus === 'success' || orderStatus === 'failed') patch.completedAt = nowIso();
  return store.updateOrder(invoice, patch, eventName);
}

app.use((error: any, _req: express.Request, res: express.Response, _next: express.NextFunction) => {
  const status = error.statusCode || 500;
  res.status(status).json({ ok: false, message: error.message || 'Internal server error', detail: error.payload });
});

