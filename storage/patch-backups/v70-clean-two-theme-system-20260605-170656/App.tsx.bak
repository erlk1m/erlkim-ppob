function maskCustomerName(value: unknown): string {
  const raw = String(value ?? '').trim();
  if (!raw) return '-';

  const words = raw
    .split(/\s+/)
    .filter(Boolean)
    // Hide generic Digiflazz testing prefix: "Nama Pelanggan Pertama" -> "Pelan**** Pert****"
    .filter((word, index) => !(index === 0 && /^nama$/i.test(word)));

  if (!words.length) return '-';

  return words
    .map((word, index) => {
      const clean = word.replace(/[^\p{L}\p{N}]/gu, '');
      if (!clean) return '****';
      const keep = index === 0 ? Math.min(5, clean.length) : Math.min(4, clean.length);
      return clean.slice(0, keep) + '****';
    })
    .join(' ');
}

function getPaymentChannelLabel(order: any, paymentMethod?: any): string {
  const paymentMethodId = String(order?.paymentMethod || order?.paymentMethodId || paymentMethod?.id || '').toLowerCase();
  const provider = String(order?.paymentProvider || paymentMethod?.provider || '').toLowerCase();

  if (provider.includes('midtrans') || paymentMethodId.includes('midtrans')) return 'Midtrans';
  if (paymentMethodId.includes('manual') || provider.includes('manual_qris')) return 'Manual QRIS';
  return paymentMethod?.name || order?.paymentMethod || order?.paymentMethodId || '-';
}

function isMidtransPaymentMethod(method?: PaymentMethod | null) {
  const id = String(method?.id || '').toLowerCase();
  const provider = String(method?.provider || '').toLowerCase();
  return provider === 'midtrans' || id.includes('midtrans');
}

function preferredPaymentMethodId(methods: PaymentMethod[]) {
  return methods.find(isMidtransPaymentMethod)?.id || methods[0]?.id || 'manual-qris';
}

function paymentMethodDisplayName(method?: PaymentMethod | null) {
  if (!method) return 'Metode pembayaran';
  return isMidtransPaymentMethod(method) ? 'Midtrans' : method.name;
}

function displayMidtransStatus(value?: string) {
  const status = String(value || 'payment_created').toLowerCase();
  if (status === 'snap_created' || status === 'payment_created') return 'payment_created';
  return status;
}


type PublicSettings = {
  site: {
    brandName?: string;
    heroTitle?: string;
    heroSubtitle?: string;
    runningText?: string;
    footerText?: string;
    whatsappNumber?: string;
  };
  theme: Record<string, unknown>;
  paymentMethods: PaymentMethod[];
};

type OrderResponse = { order: Order; events?: Array<{ id: string; type: string; message?: string; createdAt: string }> };

type WeatherModeV65 = 'normal' | 'rainstorm';

function useFetch<T>(path: string, fallback: T) {
  const [data, setData] = useState<T>(fallback);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState('');

  useEffect(() => {
    let mounted = true;
    setLoading(true);
    setError('');
    api<T>(path)
      .then((value) => mounted && setData(value))
      .catch((e) => mounted && setError(e.message || 'Gagal memuat data'))
      .finally(() => mounted && setLoading(false));
    return () => { mounted = false; };
  }, [path]);

  return { data, loading, error, setData };
}

export default function App() {
  const { data: settings } = useFetch<PublicSettings>('/settings/public', { site: {}, theme: {}, paymentMethods: [] });
  const brand = settings.site?.brandName || 'ERLKIM PULSA';
  const [weatherMode, setWeatherMode] = useState<WeatherModeV65>(() => {
    if (typeof window === 'undefined') return 'normal';
    return window.localStorage.getItem('erlkim-weather-mode') === 'rainstorm' ? 'rainstorm' : 'normal';
  });

  useEffect(() => {
    const root = document.documentElement;
    root.classList.remove('rainstorm');

    if (weatherMode === 'rainstorm') {
      root.classList.add('rainstorm');
    }

    try {
      window.localStorage.setItem('erlkim-weather-mode', weatherMode);
    } catch {}

    return () => {
      root.classList.remove('rainstorm');
    };
  }, [weatherMode]);

  return (
    <div className={`appShell weatherMode-${weatherMode}`}>
      <Header
        brand={brand}
        whatsapp={settings.site?.whatsappNumber}
        weatherMode={weatherMode}
        onToggleWeather={() => setWeatherMode((mode) => mode === 'rainstorm' ? 'normal' : 'rainstorm')}
      />
      <WeatherLayerV65 mode={weatherMode} />
      {settings.site?.runningText && <div className="running"><span>{settings.site.runningText}</span></div>}
      <main>
        <Routes>
          <Route path="/" element={<Home settings={settings} />} />
          <Route path="/produk" element={<Products />} />
          <Route path="/checkout/:id" element={<Checkout />} />
          <Route path="/tagihan" element={<Bills />} />
          <Route path="/invoice/:invoice" element={<Invoice />} />
          <Route path="/cek-pesanan" element={<CheckOrder />} />
          <Route path="/bantuan" element={<Support whatsapp={settings.site?.whatsappNumber} />} />
        </Routes>
      </main>
      <Footer text={settings.site?.footerText} whatsapp={settings.site?.whatsappNumber} />
      <MobileBottomNav />
    </div>
  );
}


function WeatherLayerV65({ mode }: { mode: WeatherModeV65 }) {
  if (mode !== 'rainstorm') return null;

  const drops = Array.from({ length: 44 }, (_, index) => {
    const left = (index * 17) % 106 - 3;
    const delay = ((index * 13) % 23) / 10;
    const duration = 0.72 + ((index * 7) % 8) / 20;
    const thick = index % 7 === 0;

    return (
      <span
        key={index}
        className={thick ? 'rainDropV65 thick' : 'rainDropV65'}
        style={{
          left: `${left}%`,
          animationDelay: `${delay}s`,
          animationDuration: `${duration}s`,
        }}
      />
    );
  });

  return (
    <div className="weatherLayerV65" aria-hidden="true">
      <div className="stormFlashV65" />
      <span className="stormCloudV65 cloudA" />
      <span className="stormCloudV65 cloudB" />
      <span className="stormCloudV65 cloudC" />
      <span className="lightningBoltV65 boltA" />
      <span className="lightningBoltV65 boltB" />
      <div className="rainDropsV65">{drops}</div>
    </div>
  );
}


function Header({ brand, whatsapp, weatherMode, onToggleWeather }: { brand: string; whatsapp?: string; weatherMode: WeatherModeV65; onToggleWeather: () => void }) {
  const [open, setOpen] = useState(false);
  const menu = [
    ['/', 'Beranda'],
    ['/produk', 'Produk'],
    ['/tagihan', 'Tagihan'],
    ['/cek-pesanan', 'Cek Pesanan'],
    ['/bantuan', 'Bantuan']
  ];

  return (
    <header className="siteHeader">
      <Link to="/" className="brand" onClick={() => setOpen(false)}>
        <span className="logoMark">EP</span>
        <span><b>{brand}</b><small>PPOB Digital</small></span>
      </Link>

      <nav className={open ? 'desktopNav open' : 'desktopNav'} aria-label="Navigasi utama">
        {menu.map(([to, label]) => <NavLink key={to} to={to} onClick={() => setOpen(false)}>{label}</NavLink>)}
      </nav>

      <div className="headerActions">
        {whatsapp && <a className="btn mini ghost desktopOnly" href={`https://wa.me/${whatsapp}`}>WhatsApp</a>}
        <button
          className={weatherMode === 'rainstorm' ? 'weatherToggle active' : 'weatherToggle'}
          type="button"
          aria-label={weatherMode === 'rainstorm' ? 'Matikan mode hujan petir' : 'Aktifkan mode hujan petir'}
          onClick={onToggleWeather}
        >
          {weatherMode === 'rainstorm' ? '☀️ Normal' : '🌧️ Hujan'}
        </button>
        <button className="hamburger" type="button" aria-label="Buka menu" onClick={() => setOpen((v) => !v)}>{open ? '×' : '☰'}</button>
      </div>
    </header>
  );
}

function MobileBottomNav() {
  const items = [
    { to: '/', icon: '⌂', label: 'Beranda' },
    { to: '/produk', icon: '▦', label: 'Produk' },
    { to: '/produk', icon: '+', label: 'Beli', primary: true },
    { to: '/tagihan', icon: '☑', label: 'Tagihan' },
    { to: '/cek-pesanan', icon: '⌕', label: 'Cek' }
  ];

  return (
    <nav className="bottomNav" aria-label="Navigasi mobile">
      {items.map((item, index) => (
        <NavLink
          key={`${item.to}-${index}`}
          to={item.to}
          className={({ isActive }) => [!item.primary && isActive ? 'active' : '', item.primary ? 'primaryAction' : ''].filter(Boolean).join(' ')}
        >
          <span>{item.icon}</span>
          {item.label}
        </NavLink>
      ))}
    </nav>
  );
}

