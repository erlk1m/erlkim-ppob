// ERLKIM V35 ADMIN ENVIRONMENT BADGE
app.get('/api/admin/environment-badge', adminOnly, (_req, res) => {
  const site: any = store.data.siteSettings || {};
  res.json(ok({
    environmentBadgeEnabled: Boolean(site.environmentBadgeEnabled),
    environmentBadgeText: site.environmentBadgeText || 'Development Testing Mode',
    environmentBadgeDescription: site.environmentBadgeDescription || 'Mode testing Digiflazz aktif. Gunakan nomor test-case untuk simulasi transaksi.',
    environmentBadgeVariant: site.environmentBadgeVariant || 'warning',
    environmentBadgeShowOnInvoice: site.environmentBadgeShowOnInvoice !== false
  }));
});

app.post('/api/admin/environment-badge', adminOnly, (req, res) => {
  const body: any = req.body || {};
  const site: any = store.data.siteSettings || (store.data.siteSettings = {});

  const toBool = (value: any, fallback: boolean) => {
    if (typeof value === 'boolean') return value;
    if (typeof value === 'string') {
      const normalized = value.toLowerCase().trim();
      if (['true', '1', 'yes', 'on'].includes(normalized)) return true;
      if (['false', '0', 'no', 'off'].includes(normalized)) return false;
    }
    return fallback;
  };

  site.environmentBadgeEnabled = toBool(body.environmentBadgeEnabled, Boolean(site.environmentBadgeEnabled));
  site.environmentBadgeText = String(body.environmentBadgeText || site.environmentBadgeText || 'Development Testing Mode').slice(0, 80);
  site.environmentBadgeDescription = String(body.environmentBadgeDescription || site.environmentBadgeDescription || 'Mode testing Digiflazz aktif. Gunakan nomor test-case untuk simulasi transaksi.').slice(0, 220);
  site.environmentBadgeVariant = String(body.environmentBadgeVariant || site.environmentBadgeVariant || 'warning').slice(0, 30);
  site.environmentBadgeShowOnInvoice = toBool(body.environmentBadgeShowOnInvoice, site.environmentBadgeShowOnInvoice !== false);
  site.updatedAt = nowIso();

  store.save();
  res.json(ok({
    environmentBadgeEnabled: Boolean(site.environmentBadgeEnabled),
    environmentBadgeText: site.environmentBadgeText,
    environmentBadgeDescription: site.environmentBadgeDescription,
    environmentBadgeVariant: site.environmentBadgeVariant,
    environmentBadgeShowOnInvoice: site.environmentBadgeShowOnInvoice !== false
  }));
});

