  '56': { message: 'Limit saldo seller', status: 'failed', transactionCreated: false, description: 'Deprecated' },
  '57': { message: 'Jumlah Digit Kurang Atau Lebih', status: 'failed', transactionCreated: true },
  '58': { message: 'Sedang Cut Off', status: 'failed', transactionCreated: true, retryable: true },
