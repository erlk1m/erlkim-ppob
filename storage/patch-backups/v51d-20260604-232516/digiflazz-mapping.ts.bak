  '65': { message: 'Limit transaksi multi', status: 'failed', transactionCreated: false, description: 'Deprecated' },
  '66': { message: 'Cut Off Perbaikan Sistem Seller', status: 'failed', transactionCreated: false, retryable: true },
  '67': { message: 'Seller belum ter-verifikasi', status: 'failed', transactionCreated: false },
  '68': { message: 'Stok habis', status: 'failed', transactionCreated: false, retryable: true },
  '69': { message: 'Harga seller lebih besar dari ketentuan harga Buyer', status: 'failed', transactionCreated: false },
  '70': { message: 'Timeout Dari Biller', status: 'failed', transactionCreated: true, retryable: true },
