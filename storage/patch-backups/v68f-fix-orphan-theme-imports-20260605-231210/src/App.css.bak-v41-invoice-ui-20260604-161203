
.qrisBoxReal {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  padding: 16px;
}

.qrisImage {
  width: 100%;
  max-width: 260px;
  height: auto;
  display: block;
  margin: 0 auto;
  border: 3px solid #111827;
  border-radius: 16px;
  background: #fff;
  padding: 12px;
}


.erlkimTestingBadge {
  position: fixed;
  left: 16px;
  right: 16px;
  bottom: 16px;
  z-index: 9999;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 4px 12px;
  align-items: center;
  max-width: 760px;
  margin: 0 auto;
  padding: 12px 14px;
  border: 3px solid #111827;
  border-radius: 16px;
  background: #facc15;
  color: #111827;
  box-shadow: 5px 5px 0 #111827;
  font-size: 13px;
}

.erlkimTestingBadge strong {
  font-size: 14px;
  line-height: 1.1;
}

.erlkimTestingBadge span {
  grid-column: 1 / 2;
  opacity: 0.9;
}

.erlkimTestingBadge button {
  grid-column: 2 / 3;
  grid-row: 1 / 3;
  width: 32px;
  height: 32px;
  border: 2px solid #111827;
  border-radius: 10px;
  background: #fff;
  color: #111827;
  font-weight: 900;
  cursor: pointer;
}

@media (max-width: 640px) {
  .erlkimTestingBadge {
    left: 10px;
    right: 10px;
    bottom: 10px;
    font-size: 12px;
  }
}
