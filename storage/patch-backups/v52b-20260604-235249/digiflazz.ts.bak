import { md5, nowIso, toBoolProductStatus } from './utils.js';


const DIGIFLAZZ_EXTRA_CATEGORY_MAP_V51: Array<[string, string]> = [
  ['paket sms', 'paket-sms-telpon'],
  ['sms', 'paket-sms-telpon'],
  ['telpon', 'paket-sms-telpon'],
  ['telepon', 'paket-sms-telpon'],
  ['masa aktif', 'masa-aktif'],
  ['aktivasi perdana', 'aktivasi-perdana'],
  ['perdana', 'aktivasi-perdana'],
  ['aktivasi voucher', 'aktivasi-voucher'],
  ['esim', 'esim'],
  ['e-sim', 'esim'],
  ['streaming', 'streaming'],
  ['tv', 'tv'],
  ['televisi', 'tv'],
  ['game', 'game'],
  ['games', 'game'],
];

function mapDigiflazzExtraCategoryV51(input: unknown): string | undefined {
  const value = String(input || '').toLowerCase();
  for (const [needle, slug] of DIGIFLAZZ_EXTRA_CATEGORY_MAP_V51) {
    if (value.includes(needle)) return slug;
  }
  return undefined;
}

import {
  DIGIFLAZZ_COMMANDS,
  DIGIFLAZZ_ENDPOINTS,
  DIGIFLAZZ_SIGNATURE_SEEDS,
  DigiflazzPriceListKind,
  isInternalDigiflazzProduct,
  mapDigiflazzCatalogCategory,
  resolveDigiflazzTestingSku,
  shouldSendTestingParam
} from './digiflazz-mapping.js';


function cleanDigiflazzEnv(value: unknown) {
  return String(value ?? '')
    .replace(/^﻿/, '')
    .trim()
    .replace(/^['"]|['"]$/g, '')
    .trim();
}

function cleanDigiflazzBaseUrl(value: unknown) {
  return cleanDigiflazzEnv(value || 'https://api.digiflazz.com/v1').replace(/\/+$/, '');
}

interface DigiflazzConfig {
  mode: 'mock' | 'development' | 'real';
  username: string;
  apiKey: string;
  baseUrl: string;
}

export class DigiflazzClient {
  private config: DigiflazzConfig;
  private log: (direction: 'request' | 'response' | 'error', action: string, payload: any) => void;

  constructor(log: DigiflazzClient['log']) {
    this.config = {
      mode: (() => {
        const rawMode = cleanDigiflazzEnv(process.env.DIGIFLAZZ_MODE).toLowerCase();
        if (rawMode === 'real' || rawMode === 'production') return 'real';
        if (rawMode === 'development' || rawMode === 'dev') return 'development';
        return 'mock';
      })(),
      username: cleanDigiflazzEnv(process.env.DIGIFLAZZ_USERNAME || process.env.DIGIFLAZZ_USER),
      apiKey: cleanDigiflazzEnv(process.env.DIGIFLAZZ_API_KEY || process.env.DIGIFLAZZ_KEY || process.env.DIGIFLAZZ_BUYER_KEY),
      baseUrl: cleanDigiflazzBaseUrl(process.env.DIGIFLAZZ_BASE_URL)
    };
    this.log = log;
  }

  status() {
    return {
      provider: 'digiflazz',
      enabled: true,
      mode: this.config.mode,
      configured: Boolean(this.config.username && this.config.apiKey),
      baseUrl: this.config.baseUrl,
      username: this.config.username ? `${this.config.username.slice(0, 3)}***` : '',
      testing: String(process.env.DIGIFLAZZ_TESTING || '').toLowerCase() === 'true',
      webhookSecretConfigured: Boolean(process.env.DIGIFLAZZ_WEBHOOK_SECRET),
      allowedIps: String(process.env.DIGIFLAZZ_ALLOWED_IPS || '').split(',').map((v) => v.trim()).filter(Boolean)
    };
  }

  private shouldMock() {
    return this.config.mode === 'mock' || !this.config.username || !this.config.apiKey;
  }

  private async post(endpoint: string, body: any, action: string) {
    if (this.shouldMock()) return this.mock(action, body);
    const url = `${this.config.baseUrl}${endpoint}`;
    this.log('request', action, { url, body });
    try {
      const response = await fetch(url, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(body)
      });
      const text = await response.text();
      const json = text ? JSON.parse(text) : {};
      this.log('response', action, { status: response.status, json });
      if (!response.ok) {
        const error: any = new Error(`Digiflazz ${action} gagal: HTTP ${response.status}`);
        error.payload = json;
        throw error;
      }
      return json;
    } catch (error: any) {
      this.log('error', action, { message: error.message, payload: error.payload });
      throw error;
    }
  }

  async checkBalance() {
    // Digiflazz Buyer API cek saldo requires:
    // cmd = "deposit" and sign = md5(username + apiKey + "depo").
    const seed = DIGIFLAZZ_SIGNATURE_SEEDS.checkBalance || 'depo';
    const body = {
      cmd: DIGIFLAZZ_COMMANDS.checkBalance,
      username: this.config.username,
      sign: md5(`${this.config.username}${this.config.apiKey}${seed}`)
    };
    return this.post(DIGIFLAZZ_ENDPOINTS.checkBalance, body, 'check-balance');
  }

  async priceList(type: DigiflazzPriceListKind = 'prepaid') {
    const body: any = {
      cmd: type === 'prepaid' ? DIGIFLAZZ_COMMANDS.priceListPrepaid : DIGIFLAZZ_COMMANDS.priceListPostpaid,
      username: this.config.username,
      sign: md5(`${this.config.username}${this.config.apiKey}${DIGIFLAZZ_SIGNATURE_SEEDS.priceList}`)
    };
    return this.post(DIGIFLAZZ_ENDPOINTS.priceList, body, `price-list-${type}`);
  }

  async inquiryPln(input: { customerNo: string }) {
    const body = {
      username: this.config.username,
      customer_no: input.customerNo,
      sign: md5(`${this.config.username}${this.config.apiKey}${input.customerNo}`)
    };
    return this.post(DIGIFLAZZ_ENDPOINTS.inquiryPln, body, 'inquiry-pln');
  }

  async prepaidTopup(input: { buyerSkuCode: string; customerNo: string; refId: string; testing?: boolean }) {
    const body = {
      username: this.config.username,
      buyer_sku_code: input.buyerSkuCode,
      customer_no: input.customerNo,
      ref_id: input.refId,
      sign: md5(`${this.config.username}${this.config.apiKey}${input.refId}`),
      testing: shouldSendTestingParam(input.testing)
    };
    return this.post(DIGIFLAZZ_ENDPOINTS.transaction, body, 'prepaid-topup');
  }

  async prepaidCheckStatus(input: { buyerSkuCode: string; customerNo: string; refId: string }) {
    return this.prepaidTopup({ ...input, testing: shouldSendTestingParam() });
  }

  async postpaidInquiry(input: { buyerSkuCode: string; customerNo: string; refId: string; testing?: boolean; amount?: number }) {
    const providerBuyerSkuCode = resolveDigiflazzTestingSku(input.buyerSkuCode, input.testing);
    const body: any = {
      commands: DIGIFLAZZ_COMMANDS.postpaidInquiry,
      username: this.config.username,
      buyer_sku_code: providerBuyerSkuCode,
      customer_no: input.customerNo,
      ref_id: input.refId,
      sign: md5(`${this.config.username}${this.config.apiKey}${input.refId}`),
      testing: shouldSendTestingParam(input.testing)
    };
    if (typeof input.amount === 'number') body.amount = input.amount;
    return this.post(DIGIFLAZZ_ENDPOINTS.transaction, body, 'postpaid-inquiry');
  }

  async postpaidPayment(input: { buyerSkuCode: string; customerNo: string; refId: string; testing?: boolean }) {
    const providerBuyerSkuCode = resolveDigiflazzTestingSku(input.buyerSkuCode, input.testing);
    const body = {
      commands: DIGIFLAZZ_COMMANDS.postpaidPayment,
      username: this.config.username,
      buyer_sku_code: providerBuyerSkuCode,
      customer_no: input.customerNo,
      ref_id: input.refId,
      sign: md5(`${this.config.username}${this.config.apiKey}${input.refId}`),
      testing: shouldSendTestingParam(input.testing)
    };
    return this.post(DIGIFLAZZ_ENDPOINTS.transaction, body, 'postpaid-payment');
  }

  async postpaidCheckStatus(input: { buyerSkuCode: string; customerNo: string; refId: string; testing?: boolean }) {
    const providerBuyerSkuCode = resolveDigiflazzTestingSku(input.buyerSkuCode, input.testing);
    const body = {
      commands: DIGIFLAZZ_COMMANDS.postpaidStatus,
      username: this.config.username,
      buyer_sku_code: providerBuyerSkuCode,
      customer_no: input.customerNo,
      ref_id: input.refId,
      sign: md5(`${this.config.username}${this.config.apiKey}${input.refId}`),
      testing: shouldSendTestingParam(input.testing)
    };
    return this.post(DIGIFLAZZ_ENDPOINTS.transaction, body, 'postpaid-status');
  }

  mapPriceListToProducts(raw: any, categories: any[], sourceType: DigiflazzPriceListKind = 'prepaid') {
    const items = Array.isArray(raw?.data) ? raw.data : [];
    return items.map((item: any) => {
      const productName = String(item.product_name || item.product || item.buyer_sku_code || '').trim();
      const buyerSkuCode = String(item.buyer_sku_code || '').trim();
      const categorySlug = mapDigiflazzCatalogCategory({ sourceType, category: item.category, brand: item.brand, name: productName, buyerSkuCode });
      const category = categories.find((c) => c.slug === categorySlug) || categories.find((c) => c.slug === 'pulsa') || categories[0];
      const providerPrice = Number(item.price || item.seller_price || item.admin || 0);
      const isPostpaid = sourceType === 'postpaid' || category?.type === 'postpaid' || categorySlug === 'tagihan';
      const margin = isPostpaid ? 0 : Math.max(400, Math.round(providerPrice * 0.02));
      const internalOnly = isInternalDigiflazzProduct(productName, buyerSkuCode);
      const active = toBoolProductStatus(item.buyer_product_status) && toBoolProductStatus(item.seller_product_status) && !internalOnly;

      return {
        id: `digiflazz-${buyerSkuCode.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`,
        provider: 'digiflazz',
        providerProductId: buyerSkuCode,
        categoryId: category.id,
        categorySlug: mapDigiflazzExtraCategoryV51((category as any).name || (category as any).label || category.slug) || category.slug,
        type: isPostpaid ? 'postpaid' : 'prepaid',
        brand: String(item.brand || item.category || 'Digiflazz').trim(),
        name: productName || buyerSkuCode,
        buyerSkuCode,
        description: String(item.desc || item.description || `${productName || buyerSkuCode} via Digiflazz`),
        providerPrice,
        sellingPrice: providerPrice + margin,
        margin,
        buyerProductStatus: toBoolProductStatus(item.buyer_product_status),
        sellerProductStatus: toBoolProductStatus(item.seller_product_status),
        isActive: active,
        isPopular: false,
        isFlashsale: false,
        updatedAt: nowIso()
      };
    }).filter((p: any) => p.buyerSkuCode);
  }

  private mock(action: string, body: any) {
    this.log('request', action, { mock: true, body });
    const response = mockResponse(action, body);
    this.log('response', action, { mock: true, response });
    return response;
  }
}

function mockResponse(action: string, body: any) {
  if (action === 'check-balance') return { data: { deposit: 90000 } };
  if (action === 'inquiry-pln') return { data: { message: 'Transaksi Sukses', status: 'Sukses', rc: '00', customer_no: body.customer_no, meter_no: body.customer_no, subscriber_id: '523300817840', name: 'DAVID', segment_power: 'R1 /000001300' } };
  if (action.startsWith('price-list-postpaid')) return { data: [
    { product_name: 'PLN Pascabayar', category: 'Pascabayar', brand: 'PLN PASCABAYAR', buyer_sku_code: 'PLNPOSTPAID', admin: 4000, commission: 0, buyer_product_status: true, seller_product_status: true, desc: '-' },
    { product_name: 'BPJS Kesehatan', category: 'Pascabayar', brand: 'BPJS KESEHATAN', buyer_sku_code: 'BPJSB', admin: 2500, commission: 0, buyer_product_status: true, seller_product_status: true, desc: '-' }
  ] };
  if (action.startsWith('price-list')) return { data: [
    { product_name: 'Telkomsel 5.000', category: 'Pulsa', brand: 'TELKOMSEL', buyer_sku_code: 'TSEL5', price: 5230, buyer_product_status: true, seller_product_status: true, desc: 'Reguler' },
    { product_name: 'Telkomsel 10.000', category: 'Pulsa', brand: 'TELKOMSEL', buyer_sku_code: 'TSEL10', price: 10150, buyer_product_status: true, seller_product_status: true, desc: 'Reguler' },
    { product_name: 'Indosat 5.000', category: 'Pulsa', brand: 'INDOSAT', buyer_sku_code: 'i5', price: 7035, buyer_product_status: true, seller_product_status: true, desc: 'Reguler' },
    { product_name: 'Telkomsel Data 2GB', category: 'Data', brand: 'TELKOMSEL', buyer_sku_code: 'TSD2', price: 22500, buyer_product_status: true, seller_product_status: true },
    { product_name: 'PLN 20.000', category: 'PLN', brand: 'PLN', buyer_sku_code: 'PLN20', price: 21970, buyer_product_status: true, seller_product_status: true },
    { product_name: 'DANA 10.000', category: 'E-Money', brand: 'DANA', buyer_sku_code: 'DANA10', price: 10100, buyer_product_status: true, seller_product_status: true },
    { product_name: 'MOBILE LEGENDS Weekly Diamond Pass', category: 'Games', brand: 'MOBILE LEGENDS', buyer_sku_code: 'GMLW1', price: 27997, buyer_product_status: true, seller_product_status: true }
  ] };
  if (action === 'postpaid-inquiry') return { data: { ref_id: body.ref_id, tr_id: body.ref_id, customer_no: body.customer_no, customer_name: 'Nama Pelanggan Pertama', buyer_sku_code: body.buyer_sku_code, admin: 2500, price: 10000, selling_price: 11000, rc: '00', status: 'Sukses', message: 'Inquiry Sukses', desc: { tarif: 'R1', daya: '1300', lembar_tagihan: '1', detail: [{ periode: '201901', nilai_tagihan: '8000', denda: '500' }] } } };
  if (action === 'postpaid-payment' || action === 'postpaid-status') return { data: { ref_id: body.ref_id, tr_id: body.ref_id, customer_no: body.customer_no, buyer_sku_code: body.buyer_sku_code, rc: '00', status: 'Sukses', message: 'Transaksi Sukses', sn: 'S1234554321N', price: 10000, selling_price: 11000, buyer_last_saldo: 90000 } };
  return { data: { ref_id: body.ref_id, customer_no: body.customer_no, buyer_sku_code: body.buyer_sku_code, rc: '00', status: 'Sukses', message: 'Transaksi Sukses', sn: `SIM-${String(body.ref_id).slice(-6)}`, price: 5800, buyer_last_saldo: 90000 } };
}
