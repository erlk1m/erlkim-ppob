app.get('/api/categories', (req, res) => res.json(ok(store.categories(req.query))));
app.get('/api/products', (req, res) => res.json(ok(store.products(req.query))));
app.get('/api/products/:id', (req, res) => {
  const product = store.productById(asSingleParam(req.params.id));
  if (!product) return res.status(404).json({ ok: false, message: 'Produk tidak ditemukan' });
  res.json(ok(product));
});
app.get('/api/payment-methods', (_req, res) => res.json(ok(store.data.paymentMethods.filter((m: any) => m.isEnabled))));

app.post('/api/store/orders', async (req, res, next) => {
  try {
    const productId = requireString(req.body.productId || req.body.buyerSkuCode, 'productId');
    const customerNo = requireString(req.body.customerNo, 'customerNo');
    const paymentMethodId = requireString(req.body.paymentMethodId || req.body.paymentMethod || 'manual-qris', 'paymentMethodId');
    const product = store.productById(productId);
    if (!product || product.type !== 'prepaid' || !product.isActive) return res.status(400).json({ ok: false, message: 'Produk prepaid tidak valid atau nonaktif' });
    const paymentMethod = store.paymentMethod(paymentMethodId);
    if (!paymentMethod) return res.status(400).json({ ok: false, message: 'Payment method tidak valid atau nonaktif' });
    const invoice = createInvoice();
    const refId = createRefId('PRE');
    const order = {
      id: invoice,
      invoice,
      refId,
      type: 'prepaid',
      productId: product.id,
      productName: product.name,
      buyerSkuCode: product.buyerSkuCode,
      customerNo,
      customerNoMasked: maskCustomerNo(customerNo),
      amount: product.sellingPrice,
      adminFee: paymentMethod.adminFee,
      totalAmount: product.sellingPrice + paymentMethod.adminFee,
      paymentMethod: paymentMethod.id,
      paymentStatus: 'unpaid',
      orderStatus: 'pending',
      providerStatus: 'waiting_payment',
      createdAt: nowIso(),
      updatedAt: nowIso()
    };
    store.addOrder(order);
    store.addPaymentLog('invoice-created', { invoice, paymentMethod: paymentMethod.id, totalAmount: order.totalAmount });
    if (isMidtransPaymentMethod(paymentMethod)) {
      const created = await createMidtransPayment(order, paymentMethod);
      return res.status(201).json(ok({ order: publicOrder(created.order), paymentMethod, midtrans: created.midtrans }));
    }
    res.status(201).json(ok({ order: publicOrder(order), paymentMethod }));
  } catch (error) { next(error); }
});


// v33 public invoice response safety middleware
const ERLKIM_PUBLIC_FINAL_PAYMENT_STATUSES = new Set(['paid', 'expired', 'canceled', 'cancelled', 'failed', 'refunded']);
const ERLKIM_PUBLIC_SENSITIVE_KEYS = new Set([
  'rawMidtransResponse',
  'rawProviderResponse',
  'signature_key',
  'va_number',
  'va_numbers',
  'customer_no',
  'customerNo',
  'customer_details',
  'merchant_id',
  'full_name',
]);
function erlkPublicInvoiceIsFinal(value) {
  const status = String(value?.data?.order?.paymentStatus || value?.order?.paymentStatus || '').toLowerCase();
  return ERLKIM_PUBLIC_FINAL_PAYMENT_STATUSES.has(status);
}
function erlkSanitizePublicInvoiceValue(value, opts = {}) {
  const finalPayment = Boolean((opts as any).finalPayment);
  const inEvents = Boolean((opts as any).inEvents);
  if (Array.isArray(value)) {
    return value.map((item) => erlkSanitizePublicInvoiceValue(item, opts));
  }
  if (!value || typeof value !== 'object') return value;
  const out = {};
  for (const [key, child] of Object.entries(value)) {
    const nextInEvents = inEvents || key === 'events';
    if (ERLKIM_PUBLIC_SENSITIVE_KEYS.has(key)) continue;
    if ((key === 'midtransToken' || key === 'midtransRedirectUrl') && (finalPayment || inEvents)) continue;
    out[key] = erlkSanitizePublicInvoiceValue(child, { finalPayment, inEvents: nextInEvents });
  }
  return out;
}
function erlkSanitizePublicInvoiceResponse(body) {
  const finalPayment = erlkPublicInvoiceIsFinal(body);
  return erlkSanitizePublicInvoiceValue(body, { finalPayment, inEvents: false });
}
app.use('/api/store/orders', (req, res, next) => {
  const originalJson = res.json.bind(res);
  res.json = (body) => originalJson(erlkSanitizePublicInvoiceResponse(body));
  next();
});
// end v33 public invoice response safety middleware

app.get('/api/store/orders/:invoice', (req, res) => {
  const order = store.orderByInvoice(asSingleParam(req.params.invoice));
  if (!order) return res.status(404).json({ ok: false, message: 'Invoice tidak ditemukan' });
  const events = (store.data.orderEvents || []).filter((e: any) => e.invoice === order.invoice).slice(0, 20);
  const paymentMethodRaw = store.data.paymentMethods.find((m: any) =>
    m.id === order.paymentMethod || m.provider === order.paymentMethod
  );

  const paymentMethod = paymentMethodRaw ? {
    id: paymentMethodRaw.id,
    provider: paymentMethodRaw.provider,
    name: paymentMethodRaw.name,
    merchantName: paymentMethodRaw.merchantName,
    adminFee: paymentMethodRaw.adminFee,
    qrisImageUrl: paymentMethodRaw.qrisImageUrl,
    qrisPayload: paymentMethodRaw.qrisPayload,
    isEnabled: paymentMethodRaw.isEnabled,
    environment: paymentMethodRaw.environment
  } : null;

  res.json(ok({ order: publicOrder(order), events, paymentMethod }));
});

app.post('/api/store/orders/:invoice/check-status', async (req, res, next) => {
  try {
    const order = store.orderByInvoice(asSingleParam(req.params.invoice));
    if (!order) return res.status(404).json({ ok: false, message: 'Invoice tidak ditemukan' });
    if (order.paymentStatus !== 'paid') return res.json(ok({ order: publicOrder(order) }, 'Pembayaran belum paid, transaksi belum dikirim ke provider'));
    if (isFinalOrderStatus(order.orderStatus)) return res.json(ok({ order: publicOrder(order) }, 'Order sudah final'));
    const result = order.type === 'postpaid'
      ? await digiflazz.postpaidCheckStatus({ buyerSkuCode: order.buyerSkuCode, customerNo: order.customerNo, refId: order.refId })
      : await digiflazz.prepaidCheckStatus({ buyerSkuCode: order.buyerSkuCode, customerNo: order.customerNo, refId: order.refId });
    const updated = applyProviderResult(order.invoice, result);
    res.json(ok(publicOrder(updated)));
  } catch (error) { next(error); }
});

app.post('/api/store/bills/inquiry', async (req, res, next) => {
  try {
    const buyerSkuCode = requireString(req.body.buyerSkuCode, 'buyerSkuCode');
    const customerNo = requireString(req.body.customerNo, 'customerNo');
    const refId = req.body.refId ? String(req.body.refId) : createRefId('PASCA');
    const result = await digiflazz.postpaidInquiry({ buyerSkuCode, customerNo, refId, testing: req.body.testing ?? true });
    const data = result.data || result;
    const inquiry = {
      id: refId,
      refId,
      trId: data.tr_id || refId,
      buyerSkuCode,
      customerNo,
      customerNoMasked: maskCustomerNo(customerNo),
      customerName: data.customer_name || data.name || '',
      adminFee: Number(data.admin || 0),
      price: Number(data.price || 0),
      sellingPrice: Number(data.selling_price || data.price || 0),
      totalAmount: Number(data.selling_price || data.price || 0) + Number(data.admin || 0),
      providerRc: data.rc,
      providerStatus: data.status,
      providerMessage: data.message,
      rawProviderResponse: data,
      createdAt: nowIso()
    };
    store.data.postpaidInquiries.unshift(inquiry);
    store.save();
    res.json(ok(publicInquiry(inquiry)));
  } catch (error) { next(error); }
});

app.post('/api/store/bills/order', async (req, res, next) => {
  try {
    const refId = requireString(req.body.refId, 'refId');
    const paymentMethodId = requireString(req.body.paymentMethodId || req.body.paymentMethod || 'manual-qris', 'paymentMethodId');
    const inquiry = store.data.postpaidInquiries.find((x: any) => x.refId === refId || x.trId === refId);
    if (!inquiry) return res.status(404).json({ ok: false, message: 'Inquiry tagihan tidak ditemukan. Lakukan cek tagihan dulu.' });
    const paymentMethod = store.paymentMethod(paymentMethodId);
    if (!paymentMethod) return res.status(400).json({ ok: false, message: 'Payment method tidak valid atau nonaktif' });
    const product = store.data.products.find((p: any) => p.buyerSkuCode === inquiry.buyerSkuCode) || { id: undefined, name: inquiry.buyerSkuCode };
    const invoice = createInvoice('BILL');
    const order = {
      id: invoice,
      invoice,
      refId: inquiry.trId || inquiry.refId,
      type: 'postpaid',
      productId: product.id,
      productName: product.name || inquiry.buyerSkuCode,
      buyerSkuCode: inquiry.buyerSkuCode,
      customerNo: inquiry.customerNo,
      customerNoMasked: inquiry.customerNoMasked,
      customerName: inquiry.customerName,
      amount: Number(inquiry.totalAmount || inquiry.sellingPrice || 0),
      providerAdminFee: Number(inquiry.adminFee || 0),
      providerSellingPrice: Number(inquiry.sellingPrice || 0),
      adminFee: Number(paymentMethod.adminFee || 0),
      totalAmount: Number(inquiry.totalAmount || inquiry.sellingPrice || 0) + Number(paymentMethod.adminFee || 0),
      paymentMethod: paymentMethod.id,
      paymentStatus: 'unpaid',
      orderStatus: 'pending',
      providerStatus: 'waiting_payment',
      rawProviderResponse: inquiry.rawProviderResponse,
      createdAt: nowIso(),
      updatedAt: nowIso()
    };
    store.addOrder(order);
    store.addPaymentLog('postpaid-invoice-created', { invoice, refId: inquiry.refId, paymentMethod: paymentMethod.id, totalAmount: order.totalAmount });
    if (isMidtransPaymentMethod(paymentMethod)) {
      const created = await createMidtransPayment(order, paymentMethod);
      return res.status(201).json(ok({ order: publicOrder(created.order), paymentMethod, midtrans: created.midtrans }));
    }
    res.status(201).json(ok({ order: publicOrder(order), paymentMethod }));
  } catch (error) { next(error); }
});


app.get('/api/admin/payments/midtrans/status', adminOnly, (_req, res) => res.json(ok(midtrans.status())));

app.post('/api/store/orders/:invoice/pay/midtrans', async (req, res, next) => {
  try {
    const order = store.orderByInvoice(asSingleParam(req.params.invoice));
    if (!order) return res.status(404).json({ ok: false, message: 'Invoice tidak ditemukan' });
    if (order.paymentStatus === 'paid') return res.status(409).json({ ok: false, message: 'Invoice sudah paid' });
    const paymentMethod = store.paymentMethod('midtrans-snap') || { id: 'midtrans-snap', provider: 'midtrans' };
    const created = await createMidtransPayment(order, paymentMethod);
    res.json(ok({ order: publicOrder(created.order), midtrans: created.midtrans }));
  } catch (error) { next(error); }
});

app.post('/api/payment/midtrans/webhook', async (req, res, next) => {
  try {
    store.addWebhookLog('midtrans', { body: req.body });
    if (!midtrans.verifyNotification(req.body)) {
      store.addPaymentLog('midtrans-signature-rejected', { orderId: req.body?.order_id, transactionStatus: req.body?.transaction_status });
      return res.status(401).json({ ok: false, message: 'Signature Midtrans tidak valid' });
    }
    const orderId = String(req.body?.order_id || '');
    const order = store.orderByInvoice(orderId);
    if (!order) return res.status(202).json(ok(null, 'Webhook Midtrans diterima, order belum ditemukan'));
    const mapped = mapMidtransPaymentStatus(req.body);
    const patch: any = {
      paymentStatus: mapped.paymentStatus,
      midtransStatus: mapped.midtransStatus,
      midtransTransactionId: req.body?.transaction_id,
      midtransPaymentType: req.body?.payment_type,
      rawMidtransResponse: req.body
    };
    if (mapped.paymentStatus === 'paid') patch.paidAt = nowIso();
    const paidOrder = store.updateOrder(order.invoice, patch, 'midtrans-webhook');
    if (mapped.paymentStatus !== 'paid') return res.json(ok(paidOrder));
    if (!paidOrder || isFinalOrderStatus(paidOrder.orderStatus)) return res.json(ok(paidOrder, 'Order sudah final'));
    const updated = await sendPaidOrderToProvider(paidOrder, 'provider-transaction', req.body.testing ?? true);
    res.json(ok(updated));
  } catch (error) { next(error); }
});

// v30 compatibility alias: Midtrans dashboard may still point to the old callback URL.
app.post('/api/payment-provider/callback/midtrans', async (req, res, next) => {
  try {
    store.addWebhookLog('midtrans', { body: req.body });
    if (!midtrans.verifyNotification(req.body)) {
      store.addPaymentLog('midtrans-signature-rejected', { orderId: req.body?.order_id, transactionStatus: req.body?.transaction_status });
      return res.status(401).json({ ok: false, message: 'Signature Midtrans tidak valid' });
    }
    const orderId = String(req.body?.order_id || '');
    const order = store.orderByInvoice(orderId);
    if (!order) return res.status(202).json(ok(null, 'Webhook Midtrans diterima, order belum ditemukan'));
    const mapped = mapMidtransPaymentStatus(req.body);
    const patch: any = {
      paymentStatus: mapped.paymentStatus,
      midtransStatus: mapped.midtransStatus,
      midtransTransactionId: req.body?.transaction_id,
      midtransPaymentType: req.body?.payment_type,
      rawMidtransResponse: req.body
    };
    if (mapped.paymentStatus === 'paid') patch.paidAt = nowIso();
    const paidOrder = store.updateOrder(order.invoice, patch, 'midtrans-webhook');
    if (mapped.paymentStatus !== 'paid') return res.json(ok(paidOrder));
    if (!paidOrder || isFinalOrderStatus(paidOrder.orderStatus)) return res.json(ok(paidOrder, 'Order sudah final'));
    const updated = await sendPaidOrderToProvider(paidOrder, 'provider-transaction', req.body.testing ?? true);
    res.json(ok(updated));
  } catch (error) { next(error); }
});

app.post('/api/admin/orders/:invoice/check-midtrans', adminOnly, async (req, res, next) => {
  try {
    const order = store.orderByInvoice(asSingleParam(req.params.invoice));
    if (!order) return res.status(404).json({ ok: false, message: 'Invoice tidak ditemukan' });
    if (order.paymentProvider !== 'midtrans' && !String(order.paymentMethod || '').includes('midtrans')) {
      return res.status(400).json({ ok: false, message: 'Order ini bukan pembayaran Midtrans' });
    }

    const status = await midtrans.transactionStatus(order.midtransOrderId || order.invoice);
    const mapped = mapMidtransPaymentStatus(status);

    const paymentPatch: any = {
      paymentStatus: mapped.paymentStatus,
      midtransStatus: mapped.midtransStatus,
      midtransTransactionId: status?.transaction_id,
      midtransPaymentType: status?.payment_type,
      rawMidtransResponse: status
    };
    if (mapped.paymentStatus === 'paid' && !order.paidAt) paymentPatch.paidAt = nowIso();

    let updatedOrder = store.updateOrder(order.invoice, paymentPatch, 'midtrans-status-synced');

    if (mapped.paymentStatus !== 'paid') {
      return res.json(ok({ order: updatedOrder, midtrans: status }, 'Status Midtrans tersinkron, pembayaran belum paid'));
    }

    if (!updatedOrder) return res.status(404).json({ ok: false, message: 'Order tidak ditemukan setelah sinkron Midtrans' });

    if (isFinalOrderStatus(updatedOrder.orderStatus)) {
      return res.json(ok({ order: updatedOrder, midtrans: status }, 'Order sudah final'));
    }

    const finalOrder = await sendPaidOrderToProvider(updatedOrder, 'provider-transaction', req.body.testing ?? true);
    res.json(ok({ order: finalOrder, midtrans: status }, 'Midtrans paid, transaksi dikirim ke Digiflazz'));
  } catch (error) { next(error); }
});

app.post('/api/provider/digiflazz/webhook', (req, res) => {
  const rawBody = (req as any).rawBody || JSON.stringify(req.body || {});
  const secret = process.env.DIGIFLAZZ_WEBHOOK_SECRET || '';
  if (secret && !verifyDigiflazzWebhookSignature(req.headers['x-hub-signature'], rawBody, secret)) {
    store.addWebhookLog('digiflazz-signature-rejected', { headers: { event: req.headers['x-digiflazz-event'], userAgent: req.headers['user-agent'] }, ip: clientIp(req) });
    return res.status(401).json({ ok: false, message: 'Signature webhook Digiflazz tidak valid' });
  }
  const allowedIps = String(process.env.DIGIFLAZZ_ALLOWED_IPS || '').split(',').map((v) => v.trim()).filter(Boolean);
  if (!ipAllowed(clientIp(req), allowedIps)) {
    store.addWebhookLog('digiflazz-ip-rejected', { ip: clientIp(req), allowedIps });
    return res.status(403).json({ ok: false, message: 'IP webhook Digiflazz tidak diizinkan' });
  }
  store.addWebhookLog('digiflazz', { headers: { event: req.headers['x-digiflazz-event'], userAgent: req.headers['user-agent'] }, body: req.body });
  const payload = req.body?.data || req.body;
  const refId = payload?.ref_id;
  const order = store.data.orders.find((o: any) => o.refId === refId || o.invoice === refId);
  if (!order) return res.status(202).json(ok(null, 'Webhook diterima, order belum ditemukan'));
  if (isFinalOrderStatus(order.orderStatus)) return res.json(ok(order, 'Order final, webhook tidak menimpa status'));
  const updated = applyProviderResult(order.invoice, { data: payload }, 'provider-webhook');
  res.json(ok(updated));
});

app.post('/api/admin/auth/login', (req, res) => {
  if (req.body.email === (process.env.ADMIN_EMAIL || 'admin@erlkim.local') && req.body.password === (process.env.ADMIN_PASSWORD || 'admin123')) {
    return res.json(ok({ token: process.env.ADMIN_TOKEN || 'change-me-admin-token', admin: { email: req.body.email, name: 'Admin ERLKIM' } }));
  }
  return res.status(401).json({ ok: false, message: 'Email atau password salah' });
});

app.get('/api/admin/dashboard', adminOnly, (_req, res) => {
  const orders = store.data.orders;
  const today = new Date().toISOString().slice(0, 10);
  const todayOrders = orders.filter((o: any) => String(o.createdAt).startsWith(today));
  res.json(ok({
    totalToday: todayOrders.length,
    success: orders.filter((o: any) => o.orderStatus === 'success').length,
    pending: orders.filter((o: any) => ['pending', 'processing', 'need_check'].includes(o.orderStatus)).length,
    omzet: orders.filter((o: any) => o.paymentStatus === 'paid').reduce((sum: number, o: any) => sum + Number(o.totalAmount || 0), 0),
    provider: digiflazz.status(),
    midtrans: midtrans.status(),
    payment: store.data.paymentMethods.map((m: any) => ({ id: m.id, provider: m.provider, enabled: m.isEnabled })),
    latestErrors: store.data.providerLogs.filter((l: any) => l.direction === 'error').slice(0, 5)
  }));
});

app.get('/api/admin/orders', adminOnly, (req, res) => {
  let orders = [...store.data.orders];
  const q = String(req.query.q || '').toLowerCase();
  if (q) orders = orders.filter((o: any) => [o.invoice, o.refId, o.customerNo, o.customerNoMasked, o.productName].some((v) => String(v).toLowerCase().includes(q)));
  if (req.query.status) orders = orders.filter((o: any) => o.orderStatus === req.query.status || o.paymentStatus === req.query.status);
  res.json(ok(orders.slice(0, Number(req.query.limit || 100))));
});

app.post('/api/admin/orders/:invoice/approve-payment', adminOnly, async (req, res, next) => {
  try {
    const order = store.orderByInvoice(asSingleParam(req.params.invoice));
    if (!order) return res.status(404).json({ ok: false, message: 'Order tidak ditemukan' });
    if (order.paymentStatus === 'paid' && isFinalOrderStatus(order.orderStatus)) return res.json(ok(order, 'Order sudah final'));
    const paidOrder = store.updateOrder(order.invoice, { paymentStatus: 'paid', paidAt: nowIso(), orderStatus: 'processing', providerStatus: 'sending_to_provider' }, 'payment-approved');
    store.addPaymentLog('manual-qris-approved', { invoice: order.invoice, by: 'admin' });
    const result = order.type === 'postpaid'
      ? await digiflazz.postpaidPayment({ buyerSkuCode: order.buyerSkuCode, customerNo: order.customerNo, refId: order.refId, testing: req.body.testing ?? true })
      : await digiflazz.prepaidTopup({ buyerSkuCode: order.buyerSkuCode, customerNo: order.customerNo, refId: order.refId, testing: req.body.testing ?? true });
    const updated = applyProviderResult(paidOrder.invoice, result, 'provider-transaction');
    res.json(ok(updated));
  } catch (error) { next(error); }
});


app.post('/api/admin/orders/:invoice/send-provider', adminOnly, async (req, res, next) => {
  try {
    const order = store.orderByInvoice(asSingleParam(req.params.invoice));
    if (!order) return res.status(404).json({ ok: false, message: 'Order tidak ditemukan' });
    if (order.paymentStatus !== 'paid') return res.status(400).json({ ok: false, message: 'Order belum paid' });
    if (isFinalOrderStatus(order.orderStatus)) return res.json(ok(order, 'Order sudah final'));
    const updated = await sendPaidOrderToProvider(order, 'provider-resend', req.body.testing ?? true);
    res.json(ok(updated));
  } catch (error) { next(error); }
});

app.post('/api/admin/orders/:invoice/cancel', adminOnly, (req, res) => {
  const order = store.orderByInvoice(asSingleParam(req.params.invoice));
  if (!order) return res.status(404).json({ ok: false, message: 'Order tidak ditemukan' });
  if (order.orderStatus === 'success') return res.status(409).json({ ok: false, message: 'Order sukses tidak boleh dibatalkan' });
  const updated = store.updateOrder(order.invoice, { paymentStatus: 'canceled', orderStatus: 'canceled', providerStatus: 'canceled_by_admin' }, 'order-canceled');
  res.json(ok(updated));
});

