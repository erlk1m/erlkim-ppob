export type DigiflazzTxnStatus = 'success' | 'failed' | 'pending';
export type DigiflazzOrderStatus = 'success' | 'failed' | 'processing' | 'need_check';
export type DigiflazzPriceListKind = 'prepaid' | 'postpaid';

