export const DIGIFLAZZ_BILLER_FIELD_MAP = {
  standard: ['ref_id', 'customer_no', 'customer_name', 'buyer_sku_code', 'admin', 'message', 'status', 'rc', 'buyer_last_saldo', 'price', 'selling_price', 'desc'],
  paymentOnly: ['sn'],
  plnDesc: ['tarif', 'daya', 'lembar_tagihan', 'detail[].periode', 'detail[].nilai_tagihan', 'detail[].admin', 'detail[].denda', 'detail[].meter_awal', 'detail[].meter_akhir'],
  pdamDesc: ['tarif', 'lembar_tagihan', 'alamat', 'jatuh_tempo', 'detail[].periode', 'detail[].nilai_tagihan', 'detail[].denda', 'detail[].meter_awal', 'detail[].meter_akhir', 'detail[].biaya_lain'],
  bpjsDesc: ['jumlah_peserta', 'lembar_tagihan', 'alamat', 'detail[].periode'],
  samsatCustomerNoFormat: 'kode_pembayaran,nomor_identitas',
  emoneyExtraRequest: ['amount']
} as const;

export function normalizeDigiflazzStatus(status?: string, rc?: string): DigiflazzOrderStatus {
  const code = String(rc || '').trim();
  const statusText = String(status || '').trim().toLowerCase();
  if (code && DIGIFLAZZ_RESPONSE_CODES[code]) {
    const mapped = DIGIFLAZZ_RESPONSE_CODES[code].status;
    if (mapped === 'success') return 'success';
    if (mapped === 'pending') return 'processing';
    return 'failed';
  }
  if (['sukses', 'success'].includes(statusText)) return 'success';
  if (['pending', 'process', 'processing'].includes(statusText)) return 'processing';
  if (['gagal', 'failed', 'fail'].includes(statusText)) return 'failed';
  return 'need_check';
}

export function responseCodeInfo(rc?: string) {
  return DIGIFLAZZ_RESPONSE_CODES[String(rc || '').trim()] || null;
}

export function isDigiflazzTestingMode(explicit?: boolean) {
  if (typeof explicit === 'boolean') return explicit;
  return isDigiflazzTestingMode(explicit);
}

export function resolveDigiflazzTestingSku(buyerSkuCode: string, explicitTesting?: boolean) {
  const sku = String(buyerSkuCode || '').trim();
  if (!sku) return sku;
  if (!isDigiflazzTestingMode(explicitTesting)) return sku;

  const exact = DIGIFLAZZ_TESTING_SKU_ALIAS[sku];
  if (exact) return exact;

  const upper = sku.toUpperCase();
  return DIGIFLAZZ_TESTING_SKU_ALIAS[upper] || sku;
}

export function shouldSendTestingParam(explicit?: boolean) {
  if (typeof explicit === 'boolean') return explicit;
  return DIGIFLAZZ_TESTING || process.env.DIGIFLAZZ_MODE !== 'real';
}

export function mapDigiflazzCatalogCategory(input: {
  sourceType: DigiflazzPriceListKind;
  category?: string;
  brand?: string;
  name?: string;
  buyerSkuCode?: string;
}) {
  const rawCategory = String(input.category || '').toLowerCase();
  const rawBrand = String(input.brand || '').toLowerCase();
  const rawName = String(input.name || '').toLowerCase();
  const rawSku = String(input.buyerSkuCode || '').toLowerCase();
  const text = `${rawCategory} ${rawBrand} ${rawName} ${rawSku}`;

  if (input.sourceType === 'postpaid') return 'tagihan';
  if (/^pln|\bpln\b|token|listrik/.test(text)) return 'token-pln';
  if (/dana|go\s*pay|gopay|ovo|shopee\s*pay|linkaja|doku|i\.saku|isaku|emoney|e-money|wallet/.test(text)) return 'emoney';
  if (/mobile legends|mobilelegend|free fire|diamond|google play|playstation|psn|voucher game|game/.test(text)) return 'voucher-game';
  if (/data|internet|kuota|freedom|xtra|aigo|flash|happy|bronnet|bronet|edukasi|ilmupedia|ketengan|gb\b|mb\b/.test(text)) return 'paket-data';

  return 'pulsa';
}

export function isInternalDigiflazzProduct(name: string, sku: string) {
  const text = `${name} ${sku}`.toLowerCase();
  return /cek status|cek hutang/.test(text);
}

export function isStorefrontPulsaBrand(brand?: string) {
  return /^(TELKOMSEL|INDOSAT|XL|AXIS|TRI|THREE|SMARTFREN|by\.U)$/i.test(String(brand || '').trim());
}
