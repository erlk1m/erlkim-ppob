import { clientIp, createInvoice, createRefId, ipAllowed, isFinalOrderStatus, mapProviderStatus, maskCustomerName, maskCustomerNo, nowIso, requireString, verifyDigiflazzWebhookSignature } from './utils.js';
import { DIGIFLAZZ_BILLER_FIELD_MAP, DIGIFLAZZ_COMMANDS, DIGIFLAZZ_ENDPOINTS, DIGIFLAZZ_RESPONSE_CODES, DIGIFLAZZ_TEST_CASES, DIGIFLAZZ_TESTING_SKU_ALIAS, DIGIFLAZZ_WEBHOOK, responseCodeInfo } from './digiflazz-mapping.js';

const app = express();

// v32: sanitize public store order response after payment is final.
// Keep Midtrans redirect/token only while the invoice is still payable.
app.use((req, res, next) => {
  try {
    if (!String(req.path || '').startsWith('/api/store/orders/')) return next();
    const originalJson = res.json.bind(res);
    res.json = (body) => {
      try {
        const finalPaymentStatuses = new Set(['paid', 'expired', 'canceled', 'cancelled', 'failed']);
        const order = body && body.data && body.data.order;
        if (order) {
          const paymentStatus = String(order.paymentStatus || '').toLowerCase();
          const orderStatus = String(order.orderStatus || '').toLowerCase();
          const midtransStatus = String(order.midtransStatus || '').toLowerCase();
          const isFinal = finalPaymentStatuses.has(paymentStatus)
            || ['success', 'canceled', 'cancelled', 'failed'].includes(orderStatus)
            || ['settlement', 'capture', 'expire', 'deny', 'cancel', 'failure'].includes(midtransStatus);
          if (isFinal) {
            delete order.midtransToken;
            delete order.midtransRedirectUrl;
          }
        }
        if (body && body.data && Array.isArray(body.data.events)) {
          body.data.events = body.data.events.map((ev) => {
            if (ev && ev.payload) {
              const p = ev.payload;
              const ps = String(p.paymentStatus || '').toLowerCase();
              const os = String(p.orderStatus || '').toLowerCase();
              const ms = String(p.midtransStatus || '').toLowerCase();
              const eventFinal = finalPaymentStatuses.has(ps)
                || ['success', 'canceled', 'cancelled', 'failed'].includes(os)
                || ['settlement', 'capture', 'expire', 'deny', 'cancel', 'failure'].includes(ms);
              if (eventFinal) {
                delete p.midtransToken;
                delete p.midtransRedirectUrl;
              }
            }
            return ev;
          });
        }
      } catch (_) {}
      return originalJson(body);
    };
    return next();
  } catch (_) {
    return next();
  }
});



// v31 public invoice sanitizer: keep public invoice safe, admin remains full.
function v31MaskName(value) {
  if (typeof value !== 'string') return value;
  return value
    .split(/\s+/)
    .filter(Boolean)
    .map((part) => {
      if (part.length <= 2) return '*'.repeat(part.length);
      return part.slice(0, 5) + '****';
    })
    .join(' ');
}

function v31MaskCustomerNo(value) {
  const raw = String(value || '');
  if (raw.length <= 6) return raw ? raw[0] + '***' : raw;
  return raw.slice(0, 5) + 'XXX' + raw.slice(-3);
}

function v31SanitizePublicValue(value) {
  if (Array.isArray(value)) return value.map(v31SanitizePublicValue).filter((item) => item !== undefined);
  if (!value || typeof value !== 'object') return value;

  const blocked = new Set([
    'rawMidtransResponse',
    'rawProviderResponse',
    'signature_key',
    'va_number',
    'va_numbers',
    'payment_amounts',
    'customer_details',
    'customer_no',
    'customerNo',
    'phone',
    'full_name',
    'merchant_id',
    'server_key',
    'serverKey',
    'apiKey',
    'api_key',
  ]);

  const out = {};
  for (const [key, val] of Object.entries(value)) {
    if (blocked.has(key)) continue;

    if (key === 'customerName' || key === 'customer_name' || key === 'fullName') {
      out[key] = v31MaskName(val);
      continue;
    }

    if (key === 'customerNoMasked' || key === 'customerNameMasked') {
      out[key] = val;
      continue;
    }

    if (/token/i.test(key) && key !== 'midtransToken') continue;
    out[key] = v31SanitizePublicValue(val);
  }
  return out;
}

function v31SanitizePublicOrderResponse(body) {
  if (!body || typeof body !== 'object') return body;
  const cloned = v31SanitizePublicValue(body);

  const order = cloned && cloned.data && cloned.data.order;
  if (order && typeof order === 'object') {
    if (order.customerNo && !order.customerNoMasked) order.customerNoMasked = v31MaskCustomerNo(order.customerNo);
    delete order.customerNo;
    if (order.customerName && !order.customerNameMasked) order.customerNameMasked = v31MaskName(order.customerName);
    if (order.customerNameMasked) order.customerName = order.customerNameMasked;
  }

  if (cloned && cloned.data && Array.isArray(cloned.data.events)) {
    cloned.data.events = cloned.data.events.map((event) => {
      const safeEvent = v31SanitizePublicValue(event);
      if (safeEvent && safeEvent.payload) safeEvent.payload = v31SanitizePublicValue(safeEvent.payload);
      return safeEvent;
    });
  }

  return cloned;
}

app.use((req, res, next) => {
  const originalJson = res.json.bind(res);
  res.json = (body) => {
    if (req.method === 'GET' && /^\/api\/store\/orders\//.test(req.path || req.url || '')) {
      return originalJson(v31SanitizePublicOrderResponse(body));
    }
    return originalJson(body);
  };
  next();
});
// end v31 public invoice sanitizer
const store = new JsonStore();
const digiflazz = new DigiflazzClient((direction, action, payload) => store.addProviderLog(direction, action, payload));
const midtrans = new MidtransClient((type, payload) => store.addPaymentLog(type, payload));
const port = Number(process.env.API_PORT || 3001);
const allowedOrigins = String(
  process.env.CORS_ORIGINS ||
  [process.env.WEB_ORIGIN || 'http://localhost:3000', process.env.ADMIN_ORIGIN || 'http://localhost:3333'].join(',')
).split(',').map((origin) => origin.trim()).filter(Boolean);

app.use(cors({
  origin(origin, callback) {
    if (!origin || allowedOrigins.includes(origin)) return callback(null, true);
    return callback(null, false);
  },
  credentials: true
}));

// v33 CORS error normalizer: avoid HTTP 500 for disallowed browser origins
app.use((err, req, res, next) => {
  const msg = String(err && err.message ? err.message : '');
  if (err && /cors|origin/i.test(msg)) {
    if (req.method === 'OPTIONS') return res.status(204).end();
    return res.status(403).json({ ok: false, message: 'CORS origin not allowed' });
  }
  return next(err);
});
// end v33 CORS error normalizer

app.set('trust proxy', true);
app.use(express.json({
  limit: '1mb',
  verify(req, _res, buf) {
    (req as any).rawBody = buf.toString('utf8');
  }
}));

function ok(data: any = null, message?: string) {
  return { ok: true, data, message };
}

function asSingleParam(value: string | string[] | undefined): string {
  if (Array.isArray(value)) return value[0] || '';
  return value || '';
}

function isMidtransPaymentMethod(paymentMethod: any) {
  const id = String(paymentMethod?.id || '').toLowerCase();
  const provider = String(paymentMethod?.provider || '').toLowerCase();
  return provider === 'midtrans' || id.includes('midtrans');
}

function publicOrder(order: any) {
  if (!order) return order;
  const safe = { ...order };
  if (safe.customerName) {
    safe.customerNameMasked = maskCustomerName(safe.customerName);
    safe.customerName = safe.customerNameMasked;
  }
  delete safe.customerNo;
  delete safe.rawProviderResponse;
  delete safe.rawMidtransResponse;
  return safe;
}

function publicInquiry(inquiry: any) {
  if (!inquiry) return inquiry;
  const safe = { ...inquiry };
  safe.customerNameMasked = maskCustomerName(inquiry.customerName);
  safe.customerName = safe.customerNameMasked;
  delete safe.customerNo;
  delete safe.rawProviderResponse;
  return safe;
}

async function createMidtransPayment(order: any, paymentMethod: any, eventName = 'midtrans-payment-created') {
  const payment = await midtrans.createSnapTransaction(order);
  const patched = store.updateOrder(order.invoice, {
    paymentMethod: paymentMethod.id,
    paymentProvider: 'midtrans',
    midtransOrderId: order.invoice,
    midtransToken: payment.token,
    midtransRedirectUrl: payment.redirect_url,
    midtransStatus: 'payment_created'
  }, eventName);
  return { order: patched, midtrans: payment };
}

async function sendPaidOrderToProvider(order: any, eventName = 'provider-transaction', testing: any = true) {
  const processingOrder = store.updateOrder(order.invoice, {
    orderStatus: 'processing',
    providerStatus: 'sending_to_provider'
  }, eventName === 'provider-resend' ? 'provider-resend' : 'midtrans-paid');

  const result = processingOrder.type === 'postpaid'
    ? await digiflazz.postpaidPayment({ buyerSkuCode: processingOrder.buyerSkuCode, customerNo: processingOrder.customerNo, refId: processingOrder.refId, testing })
    : await digiflazz.prepaidTopup({ buyerSkuCode: processingOrder.buyerSkuCode, customerNo: processingOrder.customerNo, refId: processingOrder.refId, testing });

  return applyProviderResult(processingOrder.invoice, result, eventName);
}

function adminOnly(req: express.Request, res: express.Response, next: express.NextFunction) {
  const authHeader = String(req.headers.authorization || '').trim();
  const bearerToken = authHeader.replace(/^Bearer\s+/i, '').trim();
  const xAdminToken = String(req.headers['x-admin-token'] || '').trim();
  const xApiKey = String(req.headers['x-api-key'] || '').trim();
  const queryToken = String((req.query as any)?.token || '').trim();
  const submittedToken = bearerToken || xAdminToken || xApiKey || queryToken;

  const configuredTokens = [
    process.env.ADMIN_TOKEN,
    process.env.ADMIN_API_TOKEN,
    process.env.ADMIN_SECRET,
    "erlkim-admin-2026"
  ]
    .map((value) => String(value || '').trim())
    .filter(Boolean);

  if (!submittedToken || !configuredTokens.includes(submittedToken)) {
    return res.status(401).json({ ok: false, message: 'Admin token tidak valid' });
  }
  return next();
}
app.get('/api/health', (_req, res) => res.json(ok({ status: 'ok', service: 'erlkim-ppob-api', time: nowIso() })));
app.get('/health', (_req, res) => res.json(ok({ status: 'ok', service: 'erlkim-ppob-api', time: nowIso() })));
