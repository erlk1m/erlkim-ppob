@tailwind base;
@tailwind components;
@tailwind utilities;

html, body, #root {
  min-height: 100%;
}

button {
  cursor: pointer;
}

.marquee-content {
  display: inline-block;
  white-space: nowrap;
  animation: invoice-marquee 15s linear infinite;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: .1em;
}

.marquee-content-reverse {
  display: inline-block;
  white-space: nowrap;
  animation: invoice-marquee-reverse 15s linear infinite;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: .1em;
}

@keyframes invoice-marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

@keyframes invoice-marquee-reverse {
  0% { transform: translateX(-50%); }
  100% { transform: translateX(0); }
}

.vertical-text {
  writing-mode: vertical-rl;
  text-orientation: mixed;
  display: inline-block;
  white-space: nowrap;
  animation: invoice-marquee-vertical 15s linear infinite;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: .1em;
}

.vertical-text-reverse {
  writing-mode: vertical-rl;
  text-orientation: mixed;
  display: inline-block;
  white-space: nowrap;
  animation: invoice-marquee-vertical-reverse 15s linear infinite;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: .1em;
}

@keyframes invoice-marquee-vertical {
  0% { transform: translateY(0); }
  100% { transform: translateY(-50%); }
}

@keyframes invoice-marquee-vertical-reverse {
  0% { transform: translateY(-50%); }
  100% { transform: translateY(0); }
}

@media print {
  .no-print {
    display: none !important;
  }

  .invoiceNeo {
    background: white !important;
    padding: 0 !important;
  }

  .invoice-container {
    box-shadow: none !important;
    border: 2px solid black !important;
    margin: 0 !important;
    max-width: 100% !important;
  }
}

.invoiceNeoPage {
  min-height: 100vh;
  padding: 56px 42px;
  color: #000;
  background-color: #f1f5f9;
  background-image: radial-gradient(#cbd5e1 2px, transparent 2px);
  background-size: 30px 30px;
  position: relative;
  overflow-x: hidden;
}

.invoiceMarqueeTop,
.invoiceMarqueeBottom {
  position: fixed;
  left: 0;
  z-index: 50;
  width: 100%;
  height: 32px;
  overflow: hidden;
  background: #000;
  color: #fff;
  border-color: #000;
  font-weight: 900;
  letter-spacing: .1em;
  text-transform: uppercase;
  white-space: nowrap;
}

.invoiceMarqueeTop {
  top: 0;
  border-bottom: 4px solid #000;
}

.invoiceMarqueeBottom {
  bottom: 0;
  border-top: 4px solid #000;
}

.invoiceMarqueeTop span {
  display: inline-block;
  line-height: 32px;
  animation: invoiceMarquee 16s linear infinite;
}

.invoiceMarqueeBottom span {
  display: inline-block;
  line-height: 32px;
  animation: invoiceMarqueeReverse 16s linear infinite;
}

@keyframes invoiceMarquee {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

@keyframes invoiceMarqueeReverse {
  from { transform: translateX(-50%); }
  to { transform: translateX(0); }
}

.invoiceSide {
  position: fixed;
  top: 32px;
  bottom: 32px;
  z-index: 40;
  width: 32px;
  display: grid;
  place-items: center;
  overflow: hidden;
  border-color: #000;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: .1em;
}

.invoiceSide span {
  writing-mode: vertical-rl;
  white-space: nowrap;
}

.invoiceSideLeft {
  left: 0;
  background: #facc15;
  border-right: 4px solid #000;
}

.invoiceSideRight {
  right: 0;
  background: #f472b6;
  border-left: 4px solid #000;
}

.invoiceTopbar,
.invoiceShell {
  width: min(1120px, 100%);
  margin-inline: auto;
  border: 4px solid #000;
  background: #fff;
  box-shadow: 8px 8px 0 #000;
}

.invoiceTopbar {
  min-height: 76px;
  margin-bottom: 26px;
  padding: 16px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.invoiceBrand {
  display: flex;
  align-items: center;
  gap: 14px;
  border: 0;
  background: transparent;
  color: #000;
  cursor: pointer;
}

.invoiceBrand span {
  display: inline-block;
  transform: rotate(-2deg);
  border: 4px solid #000;
  background: #00ff2a;
  padding: 4px 12px;
  font-size: 28px;
  font-weight: 950;
  line-height: 1;
}

.invoiceBrand strong {
  font-size: 30px;
  font-weight: 950;
}

.invoicePriceButton {
  border: 4px solid #000;
  background: #fde047;
  color: #000;
  padding: 10px 20px;
  font-weight: 950;
  text-decoration: none;
  box-shadow: 4px 4px 0 #000;
}

.invoiceShell {
  display: grid;
  grid-template-columns: minmax(0, 2fr) 360px;
  align-items: stretch;
}

.invoiceLeft {
  padding: 34px;
  border-right: 4px solid #000;
  min-width: 0;
}

.invoiceRight {
  padding: 28px;
  background: #f8fafc;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.invoiceHeader {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20px;
  margin-bottom: 28px;
}

.invoiceHeader h1 {
  margin: 0 0 8px;
  font-size: clamp(42px, 6vw, 58px);
  font-weight: 950;
  letter-spacing: -0.08em;
  text-transform: uppercase;
  line-height: .9;
}

.invoiceBrandBadge {
  display: inline-block;
  transform: rotate(-2deg);
  border: 2px solid #000;
  background: #facc15;
  padding: 4px 12px;
  font-weight: 900;
}

.invoiceMeta {
  display: grid;
  gap: 4px;
  text-align: right;
  font-weight: 800;
}

.invoiceMeta span,
.invoiceMeta small {
  overflow-wrap: anywhere;
}

.invoiceMeta b {
  justify-self: end;
  margin-top: 8px;
  border: 2px solid #000;
  padding: 6px 18px;
  box-shadow: 4px 4px 0 #000;
}

.statusSuccess { background: #4ade80; }
.statusPaid { background: #38bdf8; }
.statusPending { background: #facc15; }

.invoiceNotice,
.invoiceError {
  margin-bottom: 20px;
  border: 4px solid #000;
  padding: 14px;
  font-weight: 950;
  box-shadow: 4px 4px 0 #000;
}

.invoiceError {
  background: #f87171;
  color: #fff;
}

.invoiceStatusGrid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  margin-bottom: 28px;
}

.invoiceStatusCard {
  border: 4px solid #000;
  padding: 18px;
  box-shadow: 4px 4px 0 #000;
}

.invoiceStatusCard span,
.invoiceInfoCard p {
  display: block;
  margin: 0 0 8px;
  color: #6b7280;
  font-size: 12px;
  font-weight: 950;
  text-transform: uppercase;
}

.invoiceStatusCard strong {
  display: block;
  overflow-wrap: anywhere;
  font-size: 24px;
  font-weight: 950;
}

.invoiceStatusCard.yellow { background: #fde047; }
.invoiceStatusCard.blue { background: #22d3ee; }
.invoiceStatusCard.pink { background: #f472b6; }

.invoiceInfoGrid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 22px;
  margin-bottom: 34px;
}

.invoiceInfoCard {
  position: relative;
  border: 3px solid #000;
  background: #f3f4f6;
  padding: 24px 18px 18px;
  box-shadow: 4px 4px 0 #000;
  min-width: 0;
}

.infoLabel {
  position: absolute;
  top: -14px;
  left: -12px;
  border: 2px solid #000;
  padding: 3px 9px;
  font-size: 12px;
  font-weight: 950;
  text-transform: uppercase;
}

.infoLabel.blue { background: #38bdf8; }
.infoLabel.pink { background: #f472b6; }

.copyRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  margin-bottom: 14px;
}

.copyRow strong {
  min-width: 0;
  overflow-wrap: anywhere;
  font-size: 18px;
  font-weight: 950;
}

.copyRow button {
  flex: 0 0 auto;
  border: 2px solid #000;
  background: #fff;
  padding: 5px;
  box-shadow: 2px 2px 0 #000;
  cursor: pointer;
}

.greenText { color: #16a34a; }
.blueText { color: #2563eb; }

.productDetail {
  margin-bottom: 34px;
}

.productDetail h2,
.invoiceHistory h2 {
  margin: 0 0 16px;
  border-bottom: 4px solid #000;
  padding-bottom: 10px;
  font-size: 26px;
  font-weight: 950;
  text-transform: uppercase;
}

.productTable {
  border: 2px solid #000;
}

.productTableHead,
.productTableRow {
  display: grid;
  grid-template-columns: 1.5fr .7fr .8fr;
}

.productTableHead {
  background: #000;
  color: #fff;
  font-weight: 950;
  text-transform: uppercase;
}

.productTableHead span,
.productTableRow > * {
  padding: 14px;
  border-right: 2px solid #000;
}

.productTableHead span:last-child,
.productTableRow > *:last-child {
  border-right: 0;
  text-align: right;
}

.productTableRow {
  background: #fff;
}

.productTableRow strong {
  display: block;
  overflow-wrap: anywhere;
}

.productTableRow small {
  color: #6b7280;
  font-weight: 800;
}

.invoiceTotalBox {
  width: min(440px, 100%);
  margin-left: auto;
  margin-bottom: 34px;
  border: 4px solid #000;
  background: #fff;
  padding: 18px;
  box-shadow: 8px 8px 0 #000;
}

.invoiceTotalBox > div {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  color: #4b5563;
  font-weight: 900;
  margin-bottom: 12px;
}

.invoiceTotalBox .grandTotal {
  margin: 18px 0 0;
  padding-top: 18px;
  border-top: 4px solid #000;
  align-items: center;
  color: #000;
  text-transform: uppercase;
}

.grandTotal span {
  font-size: 24px;
  font-weight: 950;
}

.grandTotal strong {
  transform: rotate(1deg);
  border: 2px solid #000;
  background: #facc15;
  padding: 4px 10px;
  font-size: 30px;
  font-weight: 950;
}

.invoiceHistory > div {
  display: grid;
  gap: 10px;
}

.historyItem {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  border: 2px solid #000;
  background: #f3f4f6;
  padding: 12px;
  font-weight: 900;
}

.historyItem small {
  color: #6b7280;
  overflow-wrap: anywhere;
}

.paymentTitle {
  transform: rotate(1deg);
  margin-bottom: 26px;
  border: 4px solid #000;
  background: #38bdf8;
  padding: 14px;
  text-align: center;
  font-size: 22px;
  font-weight: 950;
  text-transform: uppercase;
  box-shadow: 4px 4px 0 #000;
}

.qrisPanel {
  position: relative;
  margin-bottom: 26px;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 4px solid #000;
  background: #fff;
  padding: 22px;
  box-shadow: 8px 8px 0 #000;
}

.tape {
  position: absolute;
  top: -14px;
  left: 50%;
  width: 66px;
  height: 24px;
  transform: translateX(-50%) rotate(-5deg);
  border: 1px solid #eab308;
  background: #fef08a;
  opacity: .85;
}

.qrisLogoText {
  margin-bottom: 16px;
  border: 4px solid #000;
  background: #fff;
  padding: 8px 18px;
  font-size: 22px;
  font-weight: 950;
}

.qrisCleanBox {
  width: 100%;
  display: grid;
  justify-items: center;
  gap: 12px;
}

.qrisCleanTitle {
  display: grid;
  justify-items: center;
  gap: 4px;
  text-align: center;
}

.qrisCleanTitle strong {
  font-size: 18px;
  font-weight: 950;
}

.qrisCleanTitle small {
  color: #4b5563;
  font-weight: 900;
}

.qrisCleanImage {
  width: min(280px, 100%);
  aspect-ratio: 1 / 1;
  display: block;
  background: #fff;
}

.qrisFallback {
  border: 3px dashed #000;
  padding: 14px;
  font-weight: 900;
}

.qrisError {
  color: #dc2626;
  font-weight: 900;
}

.qrisHelp {
  margin-top: 16px;
  width: 100%;
  border-top: 2px dashed #9ca3af;
  padding-top: 12px;
  text-align: center;
  color: #4b5563;
  font-size: 12px;
  font-weight: 800;
}

.invoiceActions {
  display: grid;
  gap: 16px;
}

.printButton,
.refreshButton {
  width: 100%;
  border: 4px solid #000;
  padding: 16px;
  font-size: 18px;
  font-weight: 950;
  text-transform: uppercase;
  letter-spacing: .05em;
  box-shadow: 4px 4px 0 #000;
  cursor: pointer;
}

.printButton { background: #f472b6; }
.refreshButton { background: #4ade80; }

.refreshButton:disabled {
  opacity: .65;
  cursor: wait;
}

@media (max-width: 900px) {
  .invoiceNeoPage {
    padding: 48px 16px;
  }

  .invoiceSide {
    display: none;
  }

  .invoiceShell {
    grid-template-columns: 1fr;
  }

  .invoiceLeft {
    border-right: 0;
    border-bottom: 4px solid #000;
    padding: 22px;
  }

  .invoiceStatusGrid,
  .invoiceInfoGrid {
    grid-template-columns: 1fr;
  }

  .invoiceHeader,
  .invoiceTopbar {
    flex-direction: column;
    align-items: flex-start;
  }

  .invoiceMeta {
    text-align: left;
  }

  .invoiceMeta b {
    justify-self: start;
  }
}

@media (max-width: 560px) {
  .productTableHead {
    display: none;
  }

  .productTableRow {
    grid-template-columns: 1fr;
  }

  .productTableRow > * {
    border-right: 0;
    border-bottom: 2px solid #000;
  }

  .productTableRow > *:last-child {
    border-bottom: 0;
    text-align: left;
  }

  .grandTotal {
    flex-direction: column;
    align-items: flex-start !important;
  }
}

@media print {
  .no-print {
    display: none !important;
  }

  .invoiceNeoPage {
    background: white !important;
    padding: 0 !important;
  }

  .invoice-container,
  .invoiceShell {
    box-shadow: none !important;
    border: 2px solid black !important;
    margin: 0 !important;
    max-width: 100% !important;
  }
}

/* Invoice polish: hilangkan header duplikat di dalam invoice view.
   Header utama atas tetap dipakai. */
.invoiceNeoPage > .invoiceTopbar {
  display: none !important;
}

/* Kurangi jarak kosong di panel QRIS kanan */
.invoiceRight {
  justify-content: flex-start !important;
  gap: 20px !important;
}

.invoiceRight > div:first-child {
  display: grid;
  gap: 18px;
}

.qrisPanel {
  margin-bottom: 0 !important;
}

.invoiceActions {
  margin-top: 0 !important;
}

/* QRIS tidak perlu membuat panel terlalu tinggi */
.qrisCleanBox {
  gap: 8px !important;
}

.qrisCleanImage {
  width: min(250px, 100%) !important;
}

/* Sedikit rapikan shell supaya tidak terlalu turun */
.invoiceShell {
  margin-top: 0 !important;
}

@media (max-width: 900px) {
  .invoiceNeoPage {
    padding-top: 48px !important;
  }
}

/* Invoice vertical watermark animation */
.invoiceSide {
  overflow: hidden !important;
}

.invoiceSideLeft span {
  display: inline-block;
  animation: invoiceSideUp 10s linear infinite;
}

.invoiceSideRight span {
  display: inline-block;
  animation: invoiceSideDown 10s linear infinite;
}

@keyframes invoiceSideUp {
  0% {
    transform: translateY(55%);
  }
  100% {
    transform: translateY(-55%);
  }
}

@keyframes invoiceSideDown {
  0% {
    transform: translateY(-55%);
  }
  100% {
    transform: translateY(55%);
  }
}

/* Mobile invoice side watermark: tetap tampil tapi lebih kecil */
@media (max-width: 900px) {
  .invoiceSide {
    display: grid !important;
    width: 20px !important;
    top: 32px !important;
    bottom: 32px !important;
    font-size: 9px !important;
    z-index: 45 !important;
  }

  .invoiceSideLeft {
    left: 0 !important;
  }

  .invoiceSideRight {
    right: 0 !important;
  }

  .invoiceNeoPage {
    padding-left: 30px !important;
    padding-right: 30px !important;
  }
}

@media (max-width: 560px) {
  .invoiceSide {
    width: 16px !important;
    font-size: 8px !important;
  }

  .invoiceNeoPage {
    padding-left: 24px !important;
    padding-right: 24px !important;
  }

  .invoiceMarqueeTop,
  .invoiceMarqueeBottom {
    height: 26px !important;
    font-size: 10px !important;
  }

  .invoiceMarqueeTop span,
  .invoiceMarqueeBottom span {
    line-height: 26px !important;
  }

  .invoiceSide {
    top: 26px !important;
    bottom: 26px !important;
  }
}

/* Fix mobile tap/click: decorative watermark must not block buttons */
.invoiceMarqueeTop,
.invoiceMarqueeBottom,
.invoiceSide {
  pointer-events: none !important;
}

.invoiceTopbar {
  position: relative !important;
  z-index: 80 !important;
}

.invoiceBrand,
.invoicePriceButton {
  pointer-events: auto !important;
  cursor: pointer !important;
}

button.invoicePriceButton {
  font: inherit;
}

@media (max-width: 900px) {
  .invoiceTopbar {
    position: relative !important;
    z-index: 80 !important;
  }

  .invoiceBrand,
  .invoicePriceButton {
    min-height: 44px !important;
    touch-action: manipulation !important;
  }
}

/* Invoice navigation click fix */
.invoiceMarqueeTop,
.invoiceMarqueeBottom,
.invoiceSide,
.invoiceSide * {
  pointer-events: none !important;
}

.invoiceTopbar {
  position: relative !important;
  z-index: 120 !important;
}

.invoiceBrand,
.invoicePriceButton {
  pointer-events: auto !important;
  cursor: pointer !important;
  text-decoration: none !important;
}

.invoiceBrand {
  border: 0 !important;
  background: transparent !important;
}

.invoicePriceButton {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  min-height: 44px !important;
  touch-action: manipulation !important;
}

/* FIX FINAL: aktifkan lagi header invoice navigation */
.invoiceNeoPage > .invoiceTopbar {
  display: flex !important;
  position: relative !important;
  z-index: 9999 !important;
  pointer-events: auto !important;
}

.invoiceNeoPage .invoiceTopbar * {
  pointer-events: auto !important;
}

.invoiceNeoPage .invoiceBrand,
.invoiceNeoPage .invoicePriceButton {
  position: relative !important;
  z-index: 10000 !important;
  pointer-events: auto !important;
  cursor: pointer !important;
  user-select: none !important;
  text-decoration: none !important;
}

/* Watermark dekorasi tidak boleh menangkap klik/tap */
.invoiceMarqueeTop,
.invoiceMarqueeTop *,
.invoiceMarqueeBottom,
.invoiceMarqueeBottom *,
.invoiceSide,
.invoiceSide * {
  pointer-events: none !important;
}

/* Supaya area header tidak ketutup watermark */
.invoiceTopbar {
  margin-top: 10px !important;
}

/* Final invoice navigation cleanup */
.invoiceNeoPage > .invoiceTopbar {
  display: flex !important;
}

.invoiceNeoPage .invoiceTopbar {
  position: relative !important;
  z-index: 9999 !important;
  pointer-events: auto !important;
}

.invoiceNeoPage .invoiceBrand,
.invoiceNeoPage .invoicePriceButton {
  pointer-events: auto !important;
  cursor: pointer !important;
  border: 0;
}

.invoiceNeoPage .invoicePriceButton {
  border: 4px solid #000 !important;
  background: #fde047 !important;
}

.invoiceMarqueeTop,
.invoiceMarqueeTop *,
.invoiceMarqueeBottom,
.invoiceMarqueeBottom *,
.invoiceSide,
.invoiceSide * {
  pointer-events: none !important;
}

/* v75B Featured Product mobile auto-scroll */
.featuredAutoWrap {
  position: relative;
  overflow: hidden;
  padding-bottom: 0.75rem;
}

.featuredAutoTrack {
  --featured-card-width: 280px;
  --featured-gap: 1rem;
  display: flex;
  gap: var(--featured-gap);
  width: max-content;
  animation: featuredAutoScroll 22s linear infinite;
  will-change: transform;
}

.featuredAutoWrap:hover .featuredAutoTrack,
.featuredAutoWrap:active .featuredAutoTrack {
  animation-play-state: paused;
}

.featuredAutoCard {
  min-width: var(--featured-card-width);
  max-width: var(--featured-card-width);
  scroll-snap-align: start;
}

@keyframes featuredAutoScroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(calc(-1 * var(--featured-count) * (var(--featured-card-width) + var(--featured-gap))));
  }
}

@media (min-width: 768px) {
  .featuredAutoWrap {
    overflow: visible;
    padding-bottom: 0;
  }

  .featuredAutoTrack {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    width: 100%;
    animation: none;
  }

  .featuredAutoCard {
    min-width: 0;
    max-width: none;
  }

  .featuredDuplicate {
    display: none;
  }
}

@media (prefers-reduced-motion: reduce) {
  .featuredAutoTrack {
    animation: none;
  }

  .featuredAutoWrap {
    overflow-x: auto;
  }
}

/* v78C Invoice History Timeline Polish */
.invoiceHistoryPolished {
  margin-top: 28px;
  border: 4px solid #000;
  background: #fffdf0;
  box-shadow: 7px 7px 0 #000;
  padding: 20px;
}

.historyHeader {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
  border-bottom: 3px solid #000;
  padding-bottom: 14px;
  margin-bottom: 16px;
}

.historyHeader h2 {
  margin: 0;
  font-size: clamp(1.45rem, 2vw, 2rem);
  font-weight: 1000;
  text-transform: uppercase;
}

.historyHeader p {
  margin: 4px 0 0;
  font-weight: 800;
  color: #4b5563;
}

.historyHeader span {
  flex: 0 0 auto;
  border: 3px solid #000;
  background: #ffde59;
  color: #000;
  box-shadow: 3px 3px 0 #000;
  padding: 8px 12px;
  font-weight: 1000;
  text-transform: uppercase;
  border-radius: 999px;
  font-size: .85rem;
}

.historyTimeline {
  position: relative;
  display: grid;
  gap: 12px;
}

.historyTimeline::before {
  content: "";
  position: absolute;
  left: 22px;
  top: 8px;
  bottom: 8px;
  width: 4px;
  background: #000;
}

.historyEvent {
  position: relative;
  display: grid;
  grid-template-columns: 48px 1fr;
  gap: 12px;
  align-items: stretch;
}

.historyIcon {
  position: relative;
  z-index: 1;
  width: 48px;
  height: 48px;
  display: grid;
  place-items: center;
  border: 3px solid #000;
  background: #e5e7eb;
  box-shadow: 3px 3px 0 #000;
  border-radius: 999px;
  font-size: 1.25rem;
}

.historyBody {
  border: 3px solid #000;
  background: #f8fafc;
  box-shadow: 4px 4px 0 #000;
  padding: 12px 14px;
}

.historyEventTop {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}

.historyEventTop strong {
  font-size: 1rem;
  font-weight: 1000;
  text-transform: uppercase;
}

.historyEventTop time {
  flex: 0 0 auto;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  font-size: .78rem;
  font-weight: 900;
  color: #4b5563;
  text-align: right;
}

.historyBody p {
  margin: 6px 0 8px;
  color: #374151;
  font-weight: 800;
  line-height: 1.35;
}

.historyBody small {
  display: inline-flex;
  width: max-content;
  max-width: 100%;
  border: 2px solid #000;
  background: #fff;
  padding: 4px 8px;
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  font-size: .72rem;
  font-weight: 1000;
  text-transform: uppercase;
  overflow-wrap: anywhere;
}

.historyTone-success .historyIcon {
  background: #00ff00;
}

.historyTone-info .historyIcon {
  background: #00ffff;
}

.historyTone-warning .historyIcon {
  background: #ffde59;
}

.historyTone-danger .historyIcon {
  background: #ff5757;
  color: #fff;
}

@media (max-width: 720px) {
  .invoiceHistoryPolished {
    padding: 14px;
    box-shadow: 5px 5px 0 #000;
  }

  .historyHeader {
    display: grid;
  }

  .historyHeader span {
    width: max-content;
  }

  .historyEvent {
    grid-template-columns: 42px 1fr;
    gap: 10px;
  }

  .historyTimeline::before {
    left: 19px;
  }

  .historyIcon {
    width: 42px;
    height: 42px;
    font-size: 1.05rem;
  }

  .historyEventTop {
    display: grid;
    gap: 5px;
  }

  .historyEventTop time {
    text-align: left;
  }
}

/* v78E Invoice Final Polish */
.invoiceStatusInsight {
  display: grid;
  grid-template-columns: 58px 1fr;
  gap: 14px;
  align-items: center;
  border: 4px solid #000;
  box-shadow: 6px 6px 0 #000;
  padding: 16px;
  margin: 22px 0;
  background: #f8fafc;
}

.invoiceStatusIcon {
  width: 58px;
  height: 58px;
  display: grid;
  place-items: center;
  border: 3px solid #000;
  border-radius: 999px;
  background: #fff;
  font-size: 1.7rem;
  box-shadow: 3px 3px 0 #000;
}

.invoiceStatusTop {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}

.invoiceStatusTop h2 {
  margin: 0;
  font-size: clamp(1.25rem, 2vw, 1.8rem);
  font-weight: 1000;
  text-transform: uppercase;
  line-height: 1.05;
}

.invoiceStatusTop span {
  flex: 0 0 auto;
  border: 3px solid #000;
  background: #fff;
  color: #000;
  box-shadow: 3px 3px 0 #000;
  padding: 6px 10px;
  font-weight: 1000;
  font-size: .78rem;
  text-transform: uppercase;
  border-radius: 999px;
}

.invoiceStatusInsight p {
  margin: 8px 0 0;
  font-weight: 900;
  line-height: 1.4;
}

.invoiceStatus-success {
  background: #00ff00;
}

.invoiceStatus-warning {
  background: #ffde59;
}

.invoiceStatus-info {
  background: #00ffff;
}

.invoiceStatus-danger {
  background: #ff5757;
  color: #fff;
}

.invoiceStatus-danger .invoiceStatusTop span {
  background: #000;
  color: #fff;
}

.snCopyRow {
  border-width: 4px !important;
  box-shadow: 5px 5px 0 #000 !important;
  margin-bottom: 12px;
}

.snCopyRow strong {
  font-size: clamp(1.1rem, 2.4vw, 1.75rem);
  letter-spacing: .04em;
  overflow-wrap: anywhere;
}

.snCopyRow button {
  min-width: max-content;
  font-weight: 1000;
}

.snReady {
  background: #00ff00 !important;
}

.snWaiting {
  background: #ffde59 !important;
}

.providerStatusPill {
  display: inline-flex;
  width: max-content;
  max-width: 100%;
  border: 3px solid #000;
  background: #fff;
  box-shadow: 3px 3px 0 #000;
  padding: 8px 12px;
  margin-top: 4px;
  font-weight: 1000;
  overflow-wrap: anywhere;
}

@media (max-width: 720px) {
  .invoiceStatusInsight {
    grid-template-columns: 1fr;
    gap: 10px;
    padding: 14px;
    box-shadow: 5px 5px 0 #000;
  }

  .invoiceStatusTop {
    display: grid;
    gap: 8px;
  }

  .invoiceStatusTop span {
    width: max-content;
  }

  .snCopyRow {
    display: grid !important;
    gap: 10px !important;
  }

  .snCopyRow button {
    width: 100%;
  }
}
