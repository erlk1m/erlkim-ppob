import { FormEvent, useEffect, useMemo, useState } from 'react';
import { api, adminHeaders, Order, PaymentMethod, Product, rupiah } from './api';


const ADMIN_CATEGORY_LABELS_V54: Record<string, string> = {
  'pulsa': 'Pulsa',
  'paket-data': 'Paket Data',
  'token-pln': 'Token PLN',
  'emoney': 'E-Money',
  'game': 'Game',
  'paket-sms-telpon': 'Paket SMS & Telpon',
  'masa-aktif': 'Masa Aktif',
  'aktivasi-perdana': 'Aktivasi Perdana',
  'aktivasi-voucher': 'Aktivasi Voucher',
  'esim': 'eSIM',
  'streaming': 'Streaming',
  'tv': 'TV',
  'tagihan': 'Tagihan',
  'voucher-game': 'Voucher Game',
};

const ADMIN_CATEGORY_ORDER_V54 = [
  'pulsa',
  'paket-data',
  'token-pln',
  'emoney',
  'game',
  'paket-sms-telpon',
  'masa-aktif',
  'aktivasi-perdana',
  'aktivasi-voucher',
  'esim',
  'streaming',
  'tv',
  'tagihan',
];

function adminCategorySlugV54(product: any) {
  return String(product?.categorySlug || product?.category || product?.type || 'lainnya');
}

function adminCategoryLabelV54(productOrSlug: any) {
  const slug = typeof productOrSlug === 'string' ? productOrSlug : adminCategorySlugV54(productOrSlug);
  return ADMIN_CATEGORY_LABELS_V54[slug] || slug;
}

function adminCategorySortIndexV54(slug: string) {
  const idx = ADMIN_CATEGORY_ORDER_V54.indexOf(String(slug || ''));
  return idx === -1 ? 999 : idx;
}



const DIGIFLAZZ_EXTRA_CATEGORY_MAP_V51: Array<[string, string]> = [
  ['paket sms', 'paket-sms-telpon'],
  ['sms', 'paket-sms-telpon'],
  ['telpon', 'paket-sms-telpon'],
  ['telepon', 'paket-sms-telpon'],
  ['masa aktif', 'masa-aktif'],
  ['aktivasi perdana', 'aktivasi-perdana'],
  ['perdana', 'aktivasi-perdana'],
  ['aktivasi voucher', 'aktivasi-voucher'],
  ['esim', 'esim'],
  ['e-sim', 'esim'],
  ['streaming', 'streaming'],
  ['tv', 'tv'],
  ['televisi', 'tv'],
  ['game', 'game'],
  ['games', 'game'],
];

function mapDigiflazzExtraCategoryV51(input: unknown): string | undefined {
  const value = String(input || '').toLowerCase();
  for (const [needle, slug] of DIGIFLAZZ_EXTRA_CATEGORY_MAP_V51) {
    if (value.includes(needle)) return slug;
  }
  return undefined;
}


type Tab = 'dashboard' | 'transaksi' | 'produk' | 'tagihan' | 'provider' | 'payment' | 'konten' | 'logs' | 'maintenance';

type Dashboard = {
  totalToday: number;
  success: number;
  pending: number;
  omzet: number;
  provider: Record<string, unknown>;
  payment: Array<{ id: string; provider: string; enabled: boolean }>;
  latestErrors: unknown[];
};

const tabs: Array<{ id: Tab; label: string; icon: string; tone: string }> = [
  { id: 'dashboard', label: 'Dashboard', icon: '⌂', tone: 'yellow' },
  { id: 'transaksi', label: 'Transaksi', icon: '↔', tone: 'green' },
  { id: 'produk', label: 'Produk', icon: '▣', tone: 'blue' },
  { id: 'tagihan', label: 'Tagihan', icon: '▤', tone: 'orange' },
  { id: 'provider', label: 'Provider', icon: '◆', tone: 'purple' },
  { id: 'payment', label: 'Payment', icon: '◎', tone: 'pink' },
  { id: 'konten', label: 'Konten Web', icon: '✎', tone: 'cyan' },
  { id: 'logs', label: 'Logs', icon: '≡', tone: 'gray' },
  { id: 'maintenance', label: 'Maintenance', icon: '⚙', tone: 'red' }
];

export default function AdminApp() {
  const [token, setToken] = useState(localStorage.getItem('adminToken') || '');
  if (!token) return <Login onLogin={setToken} />;
  return <Shell token={token} onLogout={() => { localStorage.removeItem('adminToken'); setToken(''); }} />;
}

function Login({ onLogin }: { onLogin: (token: string) => void }) {
  const [email, setEmail] = useState('admin@erlkim.local');
  const [password, setPassword] = useState('admin123');
  const [message, setMessage] = useState('');
  async function submit(e: FormEvent) {
    e.preventDefault();
    setMessage('');
    try {
      const result = await api<{ token: string }>('/admin/auth/login', { method: 'POST', body: JSON.stringify({ email, password }) });
      localStorage.setItem('adminToken', result.token);
      onLogin(result.token);
    } catch (error: any) {
      setMessage(error.message);
    }
  }
  return (
    <main className="loginPage">
      <form className="loginCard" onSubmit={submit}>
        <span className="eyebrow">Admin Panel</span>
        <h1>ERLKIM PULSA</h1>
        <p>Masuk untuk mengelola transaksi, produk Digiflazz, payment, konten web, dan logs.</p>
        <div className="loginPreview">
          <span>Dashboard</span><span>Produk</span><span>Payment</span>
        </div>
        <label>Email</label>
        <input value={email} onChange={(e) => setEmail(e.target.value)} />
        <label>Password</label>
        <input type="password" value={password} onChange={(e) => setPassword(e.target.value)} />
        {message && <div className="alert danger">{message}</div>}
        <button className="btn primary full">Masuk Admin</button>
      </form>
    </main>
  );
}

function Shell({ token, onLogout }: { token: string; onLogout: () => void }) {
  const [tab, setTab] = useState<Tab>('dashboard');
  const [tick, setTick] = useState(0);
  const [message, setMessage] = useState('');
  const auth = useMemo(() => ({ headers: adminHeaders(token) }), [token]);
  const [dashboard, setDashboard] = useState<Dashboard | null>(null);
  const [orders, setOrders] = useState<Order[]>([]);
  const [products, setProducts] = useState<Product[]>([]);
  const [payments, setPayments] = useState<PaymentMethod[]>([]);
  const [site, setSite] = useState<any>({});
  const [providerLogs, setProviderLogs] = useState<any[]>([]);
  const [paymentLogs, setPaymentLogs] = useState<any[]>([]);
  const postpaidProducts = products.filter((p) => p.type === 'postpaid');

  async function load() {
    try {
      const [dash, orderList, productList, paymentList, siteSettings, pLogs, payLogs] = await Promise.all([
        api<Dashboard>('/admin/dashboard', auth),
        api<Order[]>('/admin/orders', auth),
        api<Product[]>('/admin/products', auth),
        api<PaymentMethod[]>('/admin/payment-methods', auth),
        api<any>('/admin/site-settings', auth),
        api<any[]>('/admin/logs/provider', auth),
        api<any[]>('/admin/logs/payment', auth)
      ]);
      setDashboard(dash);
      setOrders(orderList);
      setProducts(productList);
      setPayments(paymentList);
      setSite(siteSettings);
      setProviderLogs(pLogs);
      setPaymentLogs(payLogs);
    } catch (error: any) {
      if (String(error.message || '').toLowerCase().includes('token')) onLogout();
      setMessage(error.message);
    }
  }

  useEffect(() => { load(); }, [tick, token]);

  async function post(path: string, body: any = {}) {
    setMessage('');
    try {
      await api(path, { method: 'POST', body: JSON.stringify(body), ...auth });
      setTick((value) => value + 1);
      setMessage('Aksi berhasil dijalankan.');
    } catch (error: any) {
      setMessage(error.message);
    }
  }

  async function checkBalanceSafe() {
    setMessage('');
    try {
      await api('/admin/providers/digiflazz/check-balance', { method: 'POST', body: JSON.stringify({ testing: true }), ...auth });
      setTick((value) => value + 1);
      setMessage('Aksi berhasil dijalankan. Saldo Digiflazz berhasil dibaca.');
    } catch (error: any) {
      setTick((value) => value + 1);
      setMessage(`Aksi berhasil dijalankan. Cek saldo Digiflazz bersifat opsional di mode development/testing. Transaksi tetap valid jika order testing sukses. Detail: ${error.message}`);
    }
  }

  async function patch(path: string, body: any) {
    setMessage('');
    try {
      await api(path, { method: 'PATCH', body: JSON.stringify(body), ...auth });
      setTick((value) => value + 1);
      setMessage('Data berhasil disimpan.');
    } catch (error: any) {
      setMessage(error.message);
    }
  }

  return (
    <div className="adminShell">
      <aside className="sidebar">
        <div className="brand"><span className="logo">EP</span><div><b>Admin PPOB</b><small>ERLKIM PULSA</small></div></div>
        <nav className="adminNav">{tabs.map((item) => <button key={item.id} className={`${tab === item.id ? 'active' : ''} tone-${item.tone}`} onClick={() => setTab(item.id)}><span className="navIcon">{item.icon}</span><span>{item.label}</span></button>)}</nav>
        <div className="sidebarFooter">
          <span className="miniLabel">Mode</span>
          <b>Local Dev</b>
        </div>
      </aside>
      <main className="content">
        <header className="topbar">
          <div><span className="eyebrow">Figma UI + Digiflazz</span><h1>{tabs.find((x) => x.id === tab)?.label}</h1><p>Panel admin ringkas, semua aksi diarahkan ke API backend.</p></div>
          <div className="actions"><a className="btn ghost" href="http://localhost:3000">Storefront</a><button className="btn dark" onClick={onLogout}>Logout</button></div>
        </header>
        {message && <div className={message.includes('berhasil') ? 'alert success' : 'alert danger'}>{message}</div>}
        {tab === 'dashboard' && <DashboardView dashboard={dashboard} onSync={() => post('/admin/providers/digiflazz/sync-products')} onBalance={checkBalanceSafe} onCheck={() => post('/admin/maintenance/check-processing')} />}
        {tab === 'transaksi' && <OrdersView orders={orders} approve={(invoice) => post(`/admin/orders/${invoice}/approve-payment`, { testing: true })} cancel={(invoice) => post(`/admin/orders/${invoice}/cancel`)} checkMidtrans={(invoice) => post(`/admin/orders/${invoice}/check-midtrans`, { testing: true })} checkProvider={(invoice) => post(`/store/orders/${invoice}/check-status`, { testing: true })} sendProvider={(invoice) => post(`/admin/orders/${invoice}/send-provider`, { testing: true })} />}
        {tab === 'produk' && <ProductsView products={products.filter((p) => p.type === 'prepaid')} sync={() => post('/admin/products/sync')} patch={patch} />}
        {tab === 'tagihan' && <ProductsView products={postpaidProducts} sync={() => post('/admin/providers/digiflazz/sync-products')} patch={patch} postpaid />}
        {tab === 'provider' && <ProviderView dashboard={dashboard} checkBalance={checkBalanceSafe} sync={() => post('/admin/providers/digiflazz/sync-products')} />}
        {tab === 'payment' && <PaymentView payments={payments} patch={patch} />}
        {tab === 'konten' && <ContentView site={site} setSite={setSite} save={() => patch('/admin/site-settings', site)} saveBadge={(body) => post('/admin/environment-badge', body)} />}
        {tab === 'logs' && <LogsView providerLogs={providerLogs} paymentLogs={paymentLogs} orders={orders} />}        {tab === 'maintenance' && <MaintenanceView site={site} setSite={setSite} saveSite={() => patch('/admin/site-settings', site)} expire={() => post('/admin/maintenance/expire-pending')} check={() => post('/admin/maintenance/check-processing')} />}
      </main>
    </div>
  );
}

function DashboardView({ dashboard, onSync, onBalance, onCheck }: { dashboard: Dashboard | null; onSync: () => void; onBalance: () => void; onCheck: () => void }) {
  return (
    <section>
      <div className="statGrid">
        <Stat title="Transaksi hari ini" value={dashboard?.totalToday || 0} icon="↔" tone="yellow" />
        <Stat title="Sukses" value={dashboard?.success || 0} icon="✓" tone="green" />
        <Stat title="Pending" value={dashboard?.pending || 0} icon="…" tone="orange" />
        <Stat title="Omzet paid" value={rupiah(dashboard?.omzet || 0)} icon="Rp" tone="purple" />
      </div>
      <div className="panel actionPanel">
        <div className="cardTop"><div><span className="miniLabel">Quick Action</span><h2>Aksi cepat tersambung API</h2><p>Sinkron produk, cek saldo provider, dan cek order processing tanpa tombol dummy.</p></div></div>
        <div className="quickGrid">
          <button className="quickCard yellow" onClick={onSync}><span>▣</span><b>Sync Produk</b><small>Digiflazz catalog</small></button>
          <button className="quickCard green" onClick={onBalance}><span>◎</span><b>Cek Saldo</b><small>Opsional di development</small></button>
          <button className="quickCard pink" onClick={onCheck}><span>↻</span><b>Check Processing</b><small>Order pending</small></button>
        </div>
      </div>
    </section>
  );
}

function adminOrderText(value: any, fallback = '-') {
  const text = String(value ?? '').trim();
  return text.length ? text : fallback;
}

function adminOrderTone(value: any) {
  const status = String(value ?? '').toLowerCase();

  if (['paid', 'success', 'sukses', 'settlement', '00', 'active', 'valid'].includes(status)) return 'success';
  if (['processing', 'pending', 'unpaid', 'payment_created', 'snap_created', 'waiting_payment', 'need_check'].includes(status)) return 'warning';
  if (['failed', 'gagal', 'canceled', 'cancelled', 'expired', 'off'].includes(status)) return 'danger';
  if (['midtrans', 'manual-qris', 'manual_qris', 'qris'].includes(status)) return 'info';

  return 'neutral';
}

function adminOrderPill(value: any, label?: string) {
  const text = adminOrderText(label || value);
  return <span className={`adminOrderPill ${adminOrderTone(value)}`}>{text}</span>;
}

function copyAdminText(value: any) {
  const text = String(value ?? '').trim();
  if (!text) return;

  if (typeof navigator !== 'undefined' && navigator.clipboard?.writeText) {
    navigator.clipboard.writeText(text).catch(() => {});
    return;
  }

  if (typeof document !== 'undefined') {
    const input = document.createElement('textarea');
    input.value = text;
    input.style.position = 'fixed';
    input.style.left = '-9999px';
    document.body.appendChild(input);
    input.focus();
    input.select();

    try {
      document.execCommand('copy');
    } catch (_) {
      // ignore copy fallback error
    }

    document.body.removeChild(input);
  }
}

function customerInvoiceUrl(invoice: any) {
  const safeInvoice = String(invoice ?? '').trim().replace(/[^a-zA-Z0-9-]/g, '');
  if (!safeInvoice) return '';
  return `https://store.erlkim.web.id/invoice/${encodeURIComponent(safeInvoice)}`;
}

function openCustomerInvoice(invoice: any) {
  const safeInvoice = String(invoice ?? '').trim().replace(/[^a-zA-Z0-9-]/g, '');
  if (!safeInvoice || typeof window === 'undefined') return;

  window.open(
    `https://store.erlkim.web.id/invoice/${encodeURIComponent(safeInvoice)}`,
    '_blank',
    'noopener,noreferrer'
  );
}

function adminOrderTargetNumber(order: Order) {
  const raw = order as any;
  const full = adminOrderText(raw.customerNo || raw.customer_no, '');
  const masked = adminOrderText(raw.customerNoMasked || raw.customer_no_masked, '');

  return {
    value: full || masked || '-',
    masked: masked || full || '-',
    isFull: Boolean(full)
  };
}

function adminOrderProviderSummary(order: Order) {
  const raw = order as any;
  const providerStatus = adminOrderText(raw.providerStatus || raw.provider_status, 'Belum ada status');
  const providerRc = adminOrderText(raw.providerRc || raw.provider_rc, '');
  const providerMessage = adminOrderText(raw.providerMessage || raw.provider_message, '');
  const sn = adminOrderText(raw.sn || raw.serialNumber || raw.providerSn, '');

  return { providerStatus, providerRc, providerMessage, sn };
}

function OrdersView({
  orders,
  approve,
  cancel,
  checkMidtrans,
  checkProvider,
  sendProvider
}: {
  orders: Order[];
  approve: (invoice: string) => void;
  cancel: (invoice: string) => void;
  checkMidtrans: (invoice: string) => void;
  checkProvider: (invoice: string) => void;
  sendProvider: (invoice: string) => void;
}) {
  const processingCount = orders.filter((order) => String(order.orderStatus || '').toLowerCase() === 'processing').length;
  const successCount = orders.filter((order) => String(order.orderStatus || '').toLowerCase() === 'success').length;
  const unpaidCount = orders.filter((order) => String(order.paymentStatus || '').toLowerCase() === 'unpaid').length;
  const paidCount = orders.filter((order) => String(order.paymentStatus || '').toLowerCase() === 'paid').length;
  const [orderFilter, setOrderFilter] = useState('all');
  const [orderSearch, setOrderSearch] = useState('');

  const filteredOrders = orders.filter((order) => {
    const raw = order as any;
    const paymentStatus = String(order.paymentStatus || '').toLowerCase();
    const orderStatus = String(order.orderStatus || '').toLowerCase();
    const paymentMethod = String(raw.paymentMethod || raw.payment_method || '').toLowerCase();
    const paymentProvider = String(raw.paymentProvider || raw.payment_provider || '').toLowerCase();
    const midtrans = isMidtransOrder(order);

    const haystack = [
      raw.invoice,
      raw.id,
      raw.refId,
      raw.ref_id,
      raw.productName,
      raw.product_name,
      raw.buyerSkuCode,
      raw.buyer_sku_code,
      raw.customerNo,
      raw.customer_no,
      raw.customerNoMasked,
      raw.customer_no_masked,
      raw.paymentMethod,
      raw.payment_method,
      raw.paymentProvider,
      raw.payment_provider,
      raw.paymentStatus,
      raw.payment_status,
      raw.orderStatus,
      raw.order_status,
      raw.providerStatus,
      raw.provider_status,
      raw.providerRc,
      raw.provider_rc,
      raw.providerMessage,
      raw.provider_message,
      raw.midtransStatus,
      raw.midtrans_status,
      raw.sn,
      raw.serialNumber,
      raw.providerSn
    ].map((item) => String(item || '').toLowerCase()).join(' ');

    const keyword = orderSearch.trim().toLowerCase();
    const matchesSearch = !keyword || haystack.includes(keyword);

    let matchesFilter = true;

    if (orderFilter === 'unpaid') matchesFilter = paymentStatus === 'unpaid';
    if (orderFilter === 'paid') matchesFilter = paymentStatus === 'paid';
    if (orderFilter === 'processing') matchesFilter = orderStatus === 'processing';
    if (orderFilter === 'success') matchesFilter = orderStatus === 'success';
    if (orderFilter === 'midtrans') matchesFilter = midtrans || paymentProvider.includes('midtrans') || paymentMethod.includes('midtrans');
    if (orderFilter === 'manual-qris') matchesFilter = !midtrans && (paymentMethod.includes('manual') || paymentMethod.includes('qris'));

    return matchesSearch && matchesFilter;
  });

  const filterOptions = [
    { id: 'all', label: 'Semua', count: orders.length },
    { id: 'unpaid', label: 'Unpaid', count: unpaidCount },
    { id: 'paid', label: 'Paid', count: paidCount },
    { id: 'processing', label: 'Processing', count: processingCount },
    { id: 'success', label: 'Success', count: successCount },
    { id: 'midtrans', label: 'Midtrans', count: orders.filter((order) => isMidtransOrder(order)).length },
    {
      id: 'manual-qris',
      label: 'Manual QRIS',
      count: orders.filter((order) => {
        const raw = order as any;
        const method = String(raw.paymentMethod || raw.payment_method || '').toLowerCase();
        return !isMidtransOrder(order) && (method.includes('manual') || method.includes('qris'));
      }).length
    }
  ];

  const exportFilteredOrdersCsv = () => {
    // V79G_ADMIN_EXPORT_FILTERED_ORDERS_CSV
    if (!filteredOrders.length) {
      window.alert('Tidak ada transaksi untuk diexport.');
      return;
    }

    const headers = [
      'invoice',
      'refId',
      'produk',
      'target',
      'paymentStatus',
      'orderStatus',
      'channel',
      'providerStatus',
      'providerRc',
      'sn',
      'midtransStatus'
    ];

    const escapeCsv = (value: any) => {
      const text = String(value ?? '').replace(/\r?\n/g, ' ').trim();
      return /[",;\n]/.test(text) ? `"${text.replace(/"/g, '""')}"` : text;
    };

    const rows = filteredOrders.map((order) => {
      const raw = order as any;
      const midtrans = isMidtransOrder(order);
      const target = adminOrderTargetNumber(order);
      return [
        raw.invoice,
        raw.refId || raw.ref_id,
        raw.productName || raw.product_name || raw.product?.name || raw.name || raw.buyerSkuCode || raw.buyer_sku_code,
        target.value,
        raw.paymentStatus || raw.payment_status,
        raw.orderStatus || raw.order_status,
        raw.paymentProvider || raw.payment_provider || raw.paymentMethod || raw.payment_method || (midtrans ? 'midtrans' : 'manual_qris'),
        raw.providerStatus || raw.provider_status,
        raw.providerRc || raw.provider_rc,
        raw.sn || raw.serialNumber || raw.providerSn,
        raw.midtransStatus || raw.midtrans_status
      ];
    });

    const csv = [
      headers.map(escapeCsv).join(','),
      ...rows.map((row) => row.map(escapeCsv).join(','))
    ].join('\n');

    const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    const stamp = new Date().toISOString().slice(0, 19).replace(/[:T]/g, '-');
    const safeFilter = String(orderFilter || 'all').replace(/[^a-z0-9-]/gi, '-').toLowerCase();

    link.href = url;
    link.download = `erlkim-transaksi-${safeFilter}-${stamp}.csv`;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
  };


  return (
    <div className="panel ordersPolishPanel">
      <div className="cardTop">
        <div>
          <span className="miniLabel">Admin Transaksi</span>
          <h2>Transaksi</h2>
          <p>Kelola pembayaran, status provider, SN, dan aksi order tanpa approve ulang transaksi final.</p>
        </div>

        <div className="miniStats ordersMiniStats">
          <span><b>{orders.length}</b><small>Total</small></span>
          <span><b>{unpaidCount}</b><small>Unpaid</small></span>
          <span><b>{paidCount}</b><small>Paid</small></span>
          <span><b>{processingCount}</b><small>Processing</small></span>
          <span><b>{successCount}</b><small>Success</small></span>
        </div>
      </div>

      <div className="adminGuideGrid">
        <div className="adminGuideCard warning">
          <b>Unpaid / Pending</b>
          <p>Approve hanya jika pembayaran Manual QRIS benar-benar sudah masuk.</p>
        </div>
        <div className="adminGuideCard info">
          <b>Paid / Processing</b>
          <p>Jalankan Check Provider. Jangan approve ulang.</p>
        </div>
        <div className="adminGuideCard success">
          <b>Success / Failed</b>
          <p>Status sudah final. Jangan kirim provider atau approve ulang.</p>
        </div>
      </div>

      <div className="ordersFilterPanel">
        <div className="ordersSearchBox">
          <label>Cari transaksi</label>
          <input
            value={orderSearch}
            onChange={(event) => setOrderSearch(event.target.value)}
            placeholder="Invoice, nomor tujuan, produk, SN, RC..."
          />
        </div>

        <div className="ordersFilterChips">
          {filterOptions.map((option) => (
            <button
              key={option.id}
              type="button"
              className={orderFilter === option.id ? 'active' : ''}
              onClick={() => setOrderFilter(option.id)}
            >
              <b>{option.label}</b>
              <small>{option.count}</small>
            </button>
          ))}

          {orderSearch || orderFilter !== 'all' ? (
            <button
              type="button"
              className="clear"
              onClick={() => {
                setOrderSearch('');
                setOrderFilter('all');
              }}
            >
              Reset Filter
            </button>
          ) : null}

          <button
            type="button"
            className="clear exportCsv"
            onClick={exportFilteredOrdersCsv}
            disabled={!filteredOrders.length}
          >
            Export CSV
          </button>
        </div>

        <p>
          Menampilkan <b>{filteredOrders.length}</b> dari <b>{orders.length}</b> transaksi.
        </p>
      </div>

      <div className="tableWrap ordersPolishTable">
        <table>
          <thead>
            <tr>
              <th>Invoice</th>
              <th>Produk</th>
              <th>Total</th>
              <th>Status</th>
              <th>Provider / SN</th>
              <th>Saran & Aksi</th>
            </tr>
          </thead>

          <tbody>
            {filteredOrders.length === 0 ? (
              <tr className="ordersEmptyRow">
                <td colSpan={6}>
                  <b>Tidak ada transaksi sesuai filter.</b>
                  <small>Ubah filter atau kata pencarian untuk menampilkan data lain.</small>
                </td>
              </tr>
            ) : null}

            {filteredOrders.map((order) => {
              const midtrans = isMidtransOrder(order);
              const final = isFinalOrder(order);
              const paid = String(order.paymentStatus || '').toLowerCase() === 'paid';
              const advice = orderActionAdvice(order);
              const raw = order as any;
              const provider = adminOrderProviderSummary(order);
              const target = adminOrderTargetNumber(order);
              const midtransStatus = adminOrderText(raw.midtransStatus || raw.midtrans_status, '');
              const sku = adminOrderText(raw.buyerSkuCode || raw.buyer_sku_code || raw.sku, '');
              const paymentMethod = midtrans ? 'Midtrans' : 'Manual QRIS';

              return (
                <tr key={order.invoice} className={`ordersPolishRow ${final ? 'isFinal' : ''}`}>
                  <td className="orderInvoiceCell">
                    <b>{order.invoice}</b>
                    <small>{adminOrderText(order.refId)}</small>
                    <div className="orderChannelLine">
                      {adminOrderPill(midtrans ? 'midtrans' : 'manual-qris', paymentMethod)}
                      {midtransStatus ? adminOrderPill(midtransStatus, displayMidtransStatus(midtransStatus)) : null}
                    </div>
                  </td>

                  <td className="orderProductCell">
                    <strong>{adminOrderText(order.productName)}</strong>
                    <div className="targetNumberBox">
                      <small>{target.isFull ? 'Nomor tujuan admin' : 'Nomor tujuan masked'}</small>
                      <b>{target.value}</b>
                      <button
                        type="button"
                        className="miniCopyBtn"
                        onClick={() => copyAdminText(target.value)}
                      >
                        Copy Target
                      </button>
                    </div>
                    {sku ? <span className="skuChip">SKU {sku}</span> : null}
                  </td>

                  <td className="orderTotalCell">
                    <strong>{rupiah(order.totalAmount)}</strong>
                    <small>Nominal customer</small>
                  </td>

                  <td>
                    <div className="statusStack">
                      <div>
                        <small>Payment</small>
                        {adminOrderPill(order.paymentStatus)}
                      </div>
                      <div>
                        <small>Order</small>
                        {adminOrderPill(order.orderStatus)}
                      </div>
                    </div>
                  </td>

                  <td>
                    <div className="providerMiniCard">
                      <div className="providerMiniTop">
                        <small>Provider</small>
                        {adminOrderPill(provider.providerStatus)}
                      </div>

                      <div className="providerMetaGrid">
                        <span>
                          <small>RC</small>
                          <b>{provider.providerRc || '-'}</b>
                        </span>
                        <span>
                          <small>SN</small>
                          <b>{provider.sn || '-'}</b>
                        </span>
                      </div>

                      {provider.providerMessage ? (
                        <p>{provider.providerMessage}</p>
                      ) : null}
                    </div>
                  </td>

                  <td>
                    <div className="orderActionStack">
                      <small className={`orderAdvice ${advice.tone}`}>{advice.text}</small>

                      <div className="orderActionButtons">
                        <details className="orderDetailBox" data-v79f="V79F_ADMIN_ORDER_DETAIL_MINI">
                          <summary className="tableBtn invoiceTool">Detail</summary>
                          <div className="orderDetailMini">
                            <span>
                              <b>Invoice</b>
                              <small>{adminOrderText(order.invoice)}</small>
                            </span>
                            <span>
                              <b>Ref ID</b>
                              <small>{adminOrderText(order.refId)}</small>
                            </span>
                            <span>
                              <b>Produk</b>
                              <small>{adminOrderText((order as any).productName || (order as any).product?.name || (order as any).name)}</small>
                            </span>
                            <span>
                              <b>Target</b>
                              <small>{target.value}</small>
                            </span>
                            <span>
                              <b>Payment / Order</b>
                              <small>{adminOrderText(order.paymentStatus)} / {adminOrderText(order.orderStatus)}</small>
                            </span>
                            <span>
                              <b>Channel</b>
                              <small>{adminOrderText((order as any).paymentProvider || (order as any).paymentMethod || (midtrans ? 'midtrans' : 'manual_qris'))}</small>
                            </span>
                            <span>
                              <b>Provider</b>
                              <small>{adminOrderText(provider.providerStatus)} / RC {adminOrderText(provider.providerRc)}</small>
                            </span>
                            <span>
                              <b>SN</b>
                              <small>{adminOrderText(provider.sn)}</small>
                            </span>
                            <span>
                              <b>Midtrans</b>
                              <small>{adminOrderText((order as any).midtransStatus || (midtrans ? 'midtrans' : '-'))}</small>
                            </span>
                          </div>
                        </details>
                        <button className="tableBtn invoiceTool" onClick={() => openCustomerInvoice(order.invoice)}>Buka Invoice</button>
                        <button className="tableBtn invoiceTool" onClick={() => copyAdminText(customerInvoiceUrl(order.invoice))}>Copy Link</button>
                        <button className="tableBtn invoiceTool" onClick={() => copyAdminText(order.invoice)}>Copy Invoice</button>
                        {provider.sn ? <button className="tableBtn invoiceTool" onClick={() => copyAdminText(provider.sn)}>Copy SN</button> : null}
                        {midtrans && !paid && <button className="tableBtn yellow" onClick={() => checkMidtrans(order.invoice)}>Check Midtrans</button>}
                        {!midtrans && !paid && <button className="tableBtn success" onClick={() => confirm(`Approve manual QRIS untuk ${order.invoice}? Pastikan uang sudah masuk.`) && approve(order.invoice)}>Approve</button>}
                        {paid && !final && <button className="tableBtn yellow" onClick={() => checkProvider(order.invoice)}>Check Provider</button>}
                        {paid && !final && <button className="tableBtn" onClick={() => confirm(`Kirim ulang provider untuk ${order.invoice}? Gunakan hanya jika perlu.`) && sendProvider(order.invoice)}>Kirim Provider</button>}
                        {!final && <button className="tableBtn danger" onClick={() => confirm(`Cancel ${order.invoice}?`) && cancel(order.invoice)}>Cancel</button>}
                        {final && <span className="finalNote">Final</span>}
                      </div>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  );
}

function orderActionAdvice(order: Order) {
  const payment = String(order.paymentStatus || '').toLowerCase();
  const status = String(order.orderStatus || '').toLowerCase();

  if (status === 'success') return { tone: 'success', text: 'Final sukses. Jangan approve ulang.' };
  if (status === 'failed') return { tone: 'danger', text: 'Final gagal. Cek logs provider.' };
  if (payment === 'paid' && status === 'processing') return { tone: 'info', text: 'Cek provider status.' };
  if (status === 'need_check') return { tone: 'warning', text: 'Butuh check provider.' };
  if (payment === 'unpaid') return { tone: 'warning', text: 'Tunggu bayar / approve manual.' };
  return { tone: 'muted', text: 'Cek detail order.' };
}

function ProductsView({ products, sync, patch, postpaid = false }: { products: Product[]; sync: () => void; patch: (path: string, body: any) => void; postpaid?: boolean }) {
  const groups = groupProductsByCategory(products);
  const activeCount = products.filter((product) => product.isActive).length;
  const popularCount = products.filter((product) => product.isPopular).length;
  const flashCount = products.filter((product) => product.isFlashsale).length;

  return (
    <div className="panel">
      <div className="cardTop">
        <div>
          <h2>{postpaid ? 'Produk Tagihan / Pascabayar' : 'Produk Prepaid'}</h2>
          <p>
            {postpaid
              ? 'Produk tagihan digrup per kategori agar inquiry/payment lebih mudah dicek.'
              : 'Produk prepaid digrup per kategori supaya pulsa, paket data, token, e-money, dan voucher tidak bercampur dalam satu tabel.'}
          </p>
        </div>
        <button className="btn primary" onClick={sync}>Sync Digiflazz</button>
      </div>

      <div className="miniStats">
        <span><b>{products.length}</b><small>Total</small></span>
        <span><b>{activeCount}</b><small>Active</small></span>
        <span><b>{popularCount}</b><small>Popular</small></span>
        <span><b>{flashCount}</b><small>Flash</small></span>
      </div>

      <div className="productCategorySummary">
        {groups.map((group) => (
          <button
            key={group.slug}
            type="button"
            onClick={() => document.getElementById(`cat-${group.slug}`)?.scrollIntoView({ behavior: 'smooth', block: 'start' })}
          >
            <b>{group.label}</b>
            <small>{group.items.length} produk</small>
          </button>
        ))}
      </div>

      <div className="productCategoryStack">
        {groups.length === 0 && (
          <div className="productCategoryEmpty">
            <b>Belum ada produk</b>
            <p>Jalankan Sync Digiflazz untuk mengambil produk terbaru.</p>
          </div>
        )}

        {groups.map((group) => {
          const groupActive = group.items.filter((product) => product.isActive).length;

          return (
            <section key={group.slug} id={`cat-${group.slug}`} className="productCategorySection">
              <div className="productCategoryHeader">
                <div>
                  <span className="eyebrow">Kategori</span>
                  <h3>{group.label}</h3>
                  <p>{group.items.length} produk • {groupActive} aktif</p>
                </div>
                <Badge value={group.slug} />
              </div>

              <div className="tableWrap">
                <table>
                  <thead>
                    <tr>
                      <th>Produk</th>
                      <th>SKU</th>
                      <th>Harga</th>
                      <th>Flag</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody>
                    {group.items.map((product) => (
                      <tr key={product.id}>
                        <td>
                          <b>{product.name}</b><br />
                          <small style={{ display: 'flex', gap: 6, flexWrap: 'wrap', alignItems: 'center' }}>
                            <span>{product.brand || 'Tanpa brand'}</span>
                            <span>•</span>
                            {adminCategoryLabelV54(product)}
                          </small>
                        </td>
                        <td>{product.buyerSkuCode}</td>
                        <td>{rupiah(product.sellingPrice)}<br /><small>Provider: {rupiah(product.providerPrice)}</small></td>
                        <td>
                          <Badge value={product.isActive ? 'active' : 'off'} />{' '}
                          {product.isPopular && <Badge value="popular" />}{' '}
                          {product.isFlashsale && <Badge value="flashsale" />}
                        </td>
                        <td>
                          <button className="tableBtn" onClick={() => patch(`/admin/products/${product.id}`, { isActive: !product.isActive })}>
                            {product.isActive ? 'Nonaktifkan' : 'Aktifkan'}
                          </button>
                          <button className="tableBtn yellow" onClick={() => patch(`/admin/products/${product.id}`, { isPopular: !product.isPopular })}>
                            Popular
                          </button>
                          <button className="tableBtn pink" onClick={() => patch(`/admin/products/${product.id}`, { isFlashsale: !product.isFlashsale })}>
                            Flash
                          </button>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          );
        })}
      </div>
    </div>
  );
}

function groupProductsByCategory(products: Product[]) {
  const order = ['pulsa', 'paket-data', 'token-pln', 'emoney', 'voucher-game', 'tagihan', 'game', 'paket-sms-telpon', 'masa-aktif', 'aktivasi-perdana', 'aktivasi-voucher', 'esim', 'streaming', 'tv'];
  const groups = new Map<string, Product[]>();

  for (const product of products) {
    const slug = slugSafe(product.categorySlug || product.category || product.type || 'lainnya');
    if (!groups.has(slug)) groups.set(slug, []);
    groups.get(slug)!.push(product);
  }

  return Array.from(groups.entries())
    .map(([slug, items]) => ({
      slug,
      label: formatCategoryLabel(slug),
      items: items.sort((a, b) => {
        const brandA = String(a.brand || '').localeCompare(String(b.brand || ''));
        if (brandA !== 0) return brandA;
        return Number(a.sellingPrice || 0) - Number(b.sellingPrice || 0);
      })
    }))
    .sort((a, b) => {
      const ai = order.indexOf(a.slug);
      const bi = order.indexOf(b.slug);
      if (ai !== -1 || bi !== -1) return (ai === -1 ? 999 : ai) - (bi === -1 ? 999 : bi);
      return a.label.localeCompare(b.label);
    });
}

function slugSafe(value: string) {
  return String(value || 'lainnya')
    .toLowerCase()
    .trim()
    .replace(/_/g, '-')
    .replace(/\s+/g, '-')
    .replace(/[^a-z0-9-]/g, '') || 'lainnya';
}

function formatCategoryLabel(slug: string) {
  const labels: Record<string, string> = {
    'pulsa': 'Pulsa',
    'paket-data': 'Paket Data',
    'token-pln': 'Token PLN',
    'emoney': 'E-Money',
    'voucher-game': 'Voucher Game',
    'tagihan': 'Tagihan',
  'tv': 'TV',
  'streaming': 'Streaming',
  'esim': 'eSIM',
  'aktivasi-voucher': 'Aktivasi Voucher',
  'aktivasi-perdana': 'Aktivasi Perdana',
  'masa-aktif': 'Masa Aktif',
  'paket-sms-telpon': 'Paket SMS & Telpon',
  'game': 'Game',
    'pascabayar': 'Pascabayar',
    'lainnya': 'Lainnya'
  };

  return labels[slug] || slug
    .split('-')
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
}

function ProviderView({ dashboard, checkBalance, sync }: { dashboard: Dashboard | null; checkBalance: () => void; sync: () => void }) {
  const provider: any = dashboard?.provider || {};
  const mode = String(provider.mode || provider.digiflazzMode || 'development');
  const testing = provider.testing ?? true;

  return (
    <div className="panel">
      <div className="cardTop">
        <div>
          <h2>Digiflazz Provider</h2>
          <p>Kelola status provider, sync katalog, dan cek saldo. Di mode development, cek saldo boleh gagal rc 41 tetapi transaksi testing tetap bisa sukses.</p>
        </div>
        <div className="providerModeBox">
          <Badge value={mode} />
          <Badge value={testing ? 'testing' : 'real'} />
        </div>
      </div>

      <div className="providerNotice">
        <b>Catatan Development</b>
        <p>
          Jika Cek Saldo mengembalikan rc 41 / Signature Anda salah, itu dicatat sebagai warning.
          Validasi utama mode development adalah sync produk dan transaksi test sukses, contohnya invoice INV20260604E13FA5.
        </p>
      </div>

      <div className="actions">
        <button className="btn primary" onClick={sync}>Sync Produk</button>
        <button className="btn ghost" onClick={checkBalance}>Cek Saldo Opsional</button>
      </div>

      <pre>{JSON.stringify(provider, null, 2)}</pre>
    </div>
  );
}

function PaymentView({ payments, patch }: { payments: PaymentMethod[]; patch: (path: string, body: any) => void }) {
  const manual = payments.find((method) => String(method.id || '').includes('manual') || String(method.provider || '').toLowerCase().includes('manual_qris')) as any;
  const midtrans = payments.find((method) => String(method.provider || '').toLowerCase() === 'midtrans' || String(method.id || '').toLowerCase().includes('midtrans')) as any;

  return (
    <div className="panel">
      <div className="cardTop">
        <div>
          <h2>Payment Methods</h2>
          <p>Kelola payment method aktif. Manual QRIS bersifat static dan butuh approve admin; Midtrans sandbox bisa callback otomatis.</p>
        </div>
        <div className="miniStats">
          <span><b>{payments.length}</b><small>Total</small></span>
          <span><b>{payments.filter((m) => m.isEnabled).length}</b><small>Active</small></span>
        </div>
      </div>

      <div className="paymentGuideGrid">
        <div className="paymentGuideCard yellow">
          <b>Manual QRIS</b>
          <p>QRIS static dari payload. Customer bayar sesuai total invoice, lalu admin approve manual.</p>
          <small>{manual?.qrisPayload ? `Payload OK • ${String(manual.qrisPayload).length} chars` : 'Payload belum ada'}</small>
        </div>

        <div className="paymentGuideCard blue">
          <b>Midtrans</b>
          <p>Payment gateway sandbox/production. Status paid bisa disinkron via webhook atau check Midtrans.</p>
          <small>{midtrans?.environment ? `Environment: ${midtrans.environment}` : 'Environment belum terdeteksi'}</small>
        </div>

        <div className="paymentGuideCard green">
          <b>Production Note</b>
          <p>Sebelum produksi real, pastikan QRIS merchant benar, Midtrans production key benar, dan webhook aktif.</p>
          <small>Mode sekarang masih aman untuk testing.</small>
        </div>
      </div>

      <div className="tableWrap">
        <table>
          <thead>
            <tr>
              <th>Provider</th>
              <th>Merchant</th>
              <th>Admin fee</th>
              <th>Mode</th>
              <th>QRIS / Gateway</th>
              <th>Status</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            {payments.map((method: any) => {
              const isMidtrans = String(method.provider || '').toLowerCase() === 'midtrans' || String(method.id || '').toLowerCase().includes('midtrans');
              const isManualQris = String(method.id || '').includes('manual') || String(method.provider || '').toLowerCase().includes('manual_qris');
              const hasPayload = Boolean(method.qrisPayload);
              const qrisLen = method.qrisPayload ? String(method.qrisPayload).length : 0;
              const qrisEnd = method.qrisPayload ? String(method.qrisPayload).slice(-8) : '';

              return (
                <tr key={method.id}>
                  <td>
                    <b>{formatPaymentName(method)}</b><br />
                    <small>{method.provider}</small><br />
                    <small>ID: {method.id}</small>
                  </td>
                  <td>{method.merchantName || '-'}<br /><small>{isManualQris ? 'Static merchant QRIS' : isMidtrans ? 'Payment Gateway' : 'Payment Method'}</small></td>
                  <td>{rupiah(method.adminFee)}</td>
                  <td>
                    {isMidtrans && <Badge value={method.environment || 'sandbox'} />}
                    {isManualQris && <Badge value="manual" />}
                    {!isMidtrans && !isManualQris && <Badge value="custom" />}
                  </td>
                  <td>
                    {isManualQris && (
                      <div className="paymentMiniInfo">
                        <Badge value={hasPayload ? 'payload-ok' : 'payload-missing'} />
                        <small>Length: {qrisLen || '-'}</small>
                        {qrisEnd && <small>End: {qrisEnd}</small>}
                        <small>Image: {method.qrisImageUrl ? 'external image' : 'generated from payload'}</small>
                      </div>
                    )}
                    {isMidtrans && (
                      <div className="paymentMiniInfo">
                        <Badge value={method.environment || 'sandbox'} />
                        <small>Snap payment</small>
                        <small>Webhook/check status required</small>
                      </div>
                    )}
                  </td>
                  <td><Badge value={method.isEnabled ? 'active' : 'off'} /></td>
                  <td>
                    <button className="tableBtn" onClick={() => patch(`/admin/payment-methods/${method.id}`, { isEnabled: !method.isEnabled })}>
                      {method.isEnabled ? 'Disable' : 'Enable'}
                    </button>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <div className="paymentWarningBox">
        <b>Catatan Manual QRIS</b>
        <p>Manual QRIS tidak otomatis validasi nominal dan tidak otomatis paid. Admin wajib memastikan dana masuk sebelum klik approve.</p>
      </div>
    </div>
  );
}

function ContentView({ site, setSite, save, saveBadge }: any) {
  const update = (key: string, value: any) => {
    setSite((current: any) => ({
      ...(current || {}),
      [key]: value
    }));
  };

  const field = (
    label: string,
    key: string,
    placeholder = '',
    type: 'text' | 'textarea' = 'text'
  ) => (
    <label>
      {label}
      {type === 'textarea' ? (
        <textarea
          value={site?.[key] || ''}
          placeholder={placeholder}
          onChange={(e) => update(key, e.target.value)}
          rows={3}
        />
      ) : (
        <input
          value={site?.[key] || ''}
          placeholder={placeholder}
          onChange={(e) => update(key, e.target.value)}
        />
      )}
    </label>
  );

  const Section = ({ title, description, children }: any) => (
    <div
      className="panel contentWebSection"
      style={{
        marginTop: 22,
        background: '#fff',
        border: '3px solid #000',
        borderRadius: 20,
        boxShadow: '5px 5px 0 #000'
      }}
    >
      <div style={{ marginBottom: 14 }}>
        <h3 style={{ margin: 0 }}>{title}</h3>
        {description ? <p className="muted" style={{ marginTop: 6 }}>{description}</p> : null}
      </div>
      {children}
    </div>
  );

  const previewBannerRaw = String(site?.bannerImageUrl || '/banners/home-banner.svg').trim();
  const previewBanner =
    previewBannerRaw.startsWith('http://') || previewBannerRaw.startsWith('https://')
      ? previewBannerRaw
      : `https://store.erlkim.web.id${previewBannerRaw.startsWith('/') ? previewBannerRaw : `/${previewBannerRaw}`}`;
  const previewFallbackBanner = 'https://store.erlkim.web.id/banners/home-banner.svg';

  return (
    <div className="panel contentWebRoot">
      <h2>Konten Web dari Database/API</h2>
      <p className="muted">
        Kelola teks dan banner Store. Field kosong akan memakai fallback aman dari frontend/API.
      </p>

      <Section
        title="Brand"
        description="Identitas utama yang dipakai di Store dan metadata tampilan."
      >
        <div className="formGrid">
          {field('Brand Name', 'brandName', 'ERLKIM PULSA')}
          {field('Logo URL', 'logoUrl', '/logo.png')}
        </div>
      </Section>

      <Section
        title="Homepage"
        description="Konten utama halaman depan: hero, running text, produk pilihan, dan kategori."
      >
        <div className="formGrid">
          {field('Hero Title', 'heroTitle', 'Top Up & PPOB Digital')}
          {field('Hero Subtitle', 'heroSubtitle', 'Pulsa, paket data, token PLN, e-money...', 'textarea')}
          {field('Running Text', 'runningText', 'Transaksi diproses otomatis...')}
          {field('Featured Title', 'featuredTitle', 'Produk Pilihan')}
          {field('Featured Subtitle', 'featuredSubtitle', 'Produk populer dari katalog ERLKIM.')}
          {field('Category Title', 'categoryTitle', '🛒 Kategori Produk')}
        </div>
      </Section>

      <Section
        title="Banner"
        description="Kontrol gambar banner homepage. Pakai URL lokal /banners/... agar lebih stabil dan cepat."
      >
        <div className="formGrid">
          {field('Banner Image URL', 'bannerImageUrl', '/banners/admin-home-banner.webp?v=76e1')}
        </div>

        <div
          style={{
            border: '3px solid #000',
            borderRadius: 16,
            overflow: 'hidden',
            background: '#fff',
            boxShadow: '4px 4px 0 #000',
            margin: '14px 0'
          }}
        >
          <img
            src={previewBanner}
            alt="Preview Banner Homepage"
            style={{ display: 'block', width: '100%', height: 'auto', maxHeight: 260, objectFit: 'contain', background: '#f8fafc' }}
            onError={(event) => {
              event.currentTarget.src = previewFallbackBanner;
            }}
          />
        </div>

        <div className="actions contentBannerActions">
          <button
            className="btn"
            type="button"
            onClick={() => update('bannerImageUrl', '/banners/home-banner.svg')}
          >
            Pakai Banner Default
          </button>

          <button
            className="btn"
            type="button"
            onClick={() => update('bannerImageUrl', '/banners/admin-home-banner.webp?v=76e1')}
          >
            Pakai Banner WebP Saat Ini
          </button>

          <button
            className="btn"
            type="button"
            onClick={() => update('bannerImageUrl', '')}
          >
            Kosongkan Banner
          </button>
        </div>
      </Section>

      <Section
        title="WhatsApp"
        description="Label dan nomor bantuan customer service di Store."
      >
        <div className="formGrid">
          {field('WhatsApp Label', 'whatsappLabel', 'Hubungi CS WhatsApp')}
          {field('WhatsApp Number', 'whatsappNumber', '62816262972')}
        </div>
      </Section>

      <Section
        title="Footer"
        description="Teks bagian bawah Store."
      >
        <div className="formGrid contentFullGrid">
          {field('Footer Text', 'footerText', '© ERLKIM PULSA', 'textarea')}
        </div>
      </Section>

      <div className="actions contentSaveActions" style={{ marginTop: 24 }}>
        <button className="btn primary" onClick={save}>Simpan Konten</button>
      </div>
    </div>
  );
}

function LogsView({ providerLogs, paymentLogs, orders }: { providerLogs: any[]; paymentLogs: any[]; orders: Order[] }) {
  const [query, setQuery] = useState('');
  const allLogs = mergeLogs(providerLogs, paymentLogs);
  const keywords = resolveLogKeywords(query, orders);
  const logs = filterTimelineLogs(allLogs, keywords).slice(0, 60);
  const criticalCount = allLogs.filter((log) => log.level === 'critical' || log.level === 'error').length;
  const successCount = allLogs.filter((log) => log.level === 'success').length;
  const providerCount = allLogs.filter((log) => log.source === 'provider').length;
  const paymentCount = allLogs.filter((log) => log.source === 'payment').length;

  return (
    <section className="logsPage">
      <div className="logsHero panel">
        <div>
          <span className="eyebrow">Activity Timeline</span>
          <h2>Provider & Payment Logs</h2>
          <p>Cari log berdasarkan invoice, refId, SKU, nomor tujuan, status provider, rc, atau SN. Semua tetap di menu Logs.</p>
        </div>
        <div className="logsSummary">
          <span><b>{allLogs.length}</b><small>Total</small></span>
          <span className="danger"><b>{criticalCount}</b><small>Error</small></span>
          <span className="success"><b>{successCount}</b><small>OK</small></span>
          <span><b>{providerCount}/{paymentCount}</b><small>Provider/Pay</small></span>
        </div>
      </div>

      <div className="logSearch panel">
        <label>
          Cari Log
          <input
            value={query}
            onChange={(e) => setQuery(e.target.value)}
            placeholder="INV20260604... / PRE-... / x10 / Pending / Sukses / rc 00"
          />
        </label>
        <div className="logSearchHelp">
          {keywords.length > 0 ? (
            <span>Keyword aktif: <b>{keywords.join(', ')}</b></span>
          ) : (
            <span>Kosongkan pencarian untuk melihat log terbaru.</span>
          )}
          <button className="tableBtn" type="button" onClick={() => setQuery('')}>Reset</button>
        </div>
      </div>

      <div className="logQuickFilters">
        <button type="button" onClick={() => setQuery('')}>Terbaru</button>
        <button type="button" onClick={() => setQuery('Pending')}>Pending</button>
        <button type="button" onClick={() => setQuery('Sukses')}>Sukses</button>
        <button type="button" onClick={() => setQuery('rc 00')}>RC 00</button>
        <button type="button" onClick={() => setQuery('signature')}>Signature</button>
      </div>

      <div className="logFilters" aria-label="Log category preview">
        <span className="logFilter active">Semua</span>
        <span className="logFilter critical">Critical</span>
        <span className="logFilter provider">Provider</span>
        <span className="logFilter payment">Payment</span>
      </div>

      <div className="logTimeline">
        {logs.length === 0 && (
          <div className="logEmpty">
            <b>-- Tidak Ada Log Cocok --</b>
            <span>Coba cari pakai refId, SKU, nomor tujuan, status, atau kosongkan pencarian.</span>
          </div>
        )}

        {logs.map((log) => (
          <article key={log.id} className={`logEntry ${log.level}`}>
            <time className="logTime">{log.time}</time>
            <div className="logCard">
              <div className="logHead">
                <div className="logTitle"><span className="logIcon">{log.icon}</span><b>{log.title}</b></div>
                <span className="logCode">{log.code}</span>
              </div>
              <p>{highlightLogMessage(log.message, keywords)}</p>
              <div className="logMeta">
                <span>ID: {log.shortId}</span>
                <span>{log.source.toUpperCase()}</span>
                <span>{log.actor}</span>
              </div>
              {log.payload && <details className="logRaw"><summary>Raw payload</summary><pre>{log.payload}</pre></details>}
            </div>
          </article>
        ))}

        {logs.length > 0 && <div className="logEnd">-- End of Log --</div>}
      </div>
    </section>
  );
}

function resolveLogKeywords(query: string, orders: Order[]) {
  const raw = String(query || '').trim();
  if (!raw) return [];

  const match = orders.find((order) =>
    String(order.invoice || '').toLowerCase() === raw.toLowerCase()
    || String(order.refId || '').toLowerCase() === raw.toLowerCase()
  );

  const values = [
    raw,
    match?.invoice,
    match?.refId,
    match?.buyerSkuCode,
    match?.productName,
    match?.customerNoMasked,
    match?.providerStatus,
    match?.providerRc,
    match?.sn
  ].filter(Boolean).map((value) => String(value).toLowerCase());

  return Array.from(new Set(values));
}

function filterTimelineLogs(logs: TimelineLog[], keywords: string[]) {
  if (!keywords.length) return logs.slice(0, 60);

  return logs.filter((log) => {
    const hay = `${log.title} ${log.message} ${log.code} ${log.actor} ${log.payload}`.toLowerCase();
    return keywords.some((keyword) => hay.includes(keyword));
  });
}

function highlightLogMessage(message: string, keywords: string[]) {
  if (!keywords.length) return message;
  const first = keywords.find((keyword) => message.toLowerCase().includes(keyword));
  if (!first) return message;
  return `🔎 ${message}`;
}

type TimelineLog = {
  id: string;
  source: 'provider' | 'payment';
  level: 'critical' | 'error' | 'warning' | 'success' | 'info';
  title: string;
  message: string;
  code: string;
  time: string;
  shortId: string;
  actor: string;
  icon: string;
  payload: string;
  createdAt: string;
};

function mergeLogs(providerLogs: any[], paymentLogs: any[]): TimelineLog[] {
  const provider = providerLogs.map((log) => normalizeLog(log, 'provider' as const));
  const payment = paymentLogs.map((log) => normalizeLog(log, 'payment' as const));
  return [...provider, ...payment].sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());
}

function normalizeLog(log: any, source: 'provider' | 'payment'): TimelineLog {
  const createdAt = log?.createdAt || log?.created_at || new Date().toISOString();
  const raw = log?.payload ?? log?.raw ?? log;
  const rawText = safeJson(raw);
  const action = String(log?.action || log?.type || log?.direction || source);
  const text = `${action} ${rawText}`.toLowerCase();
  const isError = text.includes('error') || text.includes('failed') || text.includes('timeout') || text.includes('exception') || text.includes('500') || log?.direction === 'error';
  const isWarning = text.includes('pending') || text.includes('need_check') || text.includes('warning') || text.includes('retry');
  const isSuccess = text.includes('success') || text.includes('sukses') || text.includes('paid') || text.includes('200') || text.includes('201') || text.includes('rc\":\"00') || text.includes('rc: 00');
  const level: TimelineLog['level'] = isError ? 'critical' : isWarning ? 'warning' : isSuccess ? 'success' : 'info';
  const statusCode = isError ? '500 ERR' : isWarning ? '102 WAIT' : isSuccess ? '200 OK' : 'LOG';

  return {
    id: `${source}-${log?.id || createdAt}-${action}`,
    source,
    level,
    title: titleFromAction(action, source, level),
    message: messageFromLog(log, raw, source),
    code: statusCode,
    time: formatLogTime(createdAt),
    shortId: String(log?.id || createdAt).slice(-6).toUpperCase(),
    actor: source === 'provider' ? 'DIGIFLAZZ' : 'PAYMENT',
    icon: iconFromLevel(level, source),
    payload: rawText,
    createdAt
  };
}

function formatLogTime(value: string) {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return '--:--';
  return date.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
}

function titleFromAction(action: string, source: string, level: TimelineLog['level']) {
  if (level === 'critical') return 'Critical Failure';
  if (action.includes('balance')) return 'Balance Check';
  if (action.includes('sync')) return 'Product Sync';
  if (action.includes('callback')) return 'Payment Callback';
  if (action.includes('webhook')) return 'Webhook Event';
  if (action.includes('order')) return 'Order Action';
  return source === 'provider' ? 'Provider Log' : 'Payment Log';
}

function messageFromLog(log: any, raw: any, source: string) {
  const action = log?.action || log?.type || log?.direction || source;
  const message = raw?.message || raw?.data?.message || raw?.status || raw?.rc || raw?.invoice || raw?.ref_id;
  return `${String(action).replaceAll('-', ' ')}${message ? ` — ${String(message)}` : ''}`;
}

function iconFromLevel(level: TimelineLog['level'], source: string) {
  if (level === 'critical' || level === 'error') return '⚠';
  if (level === 'warning') return '↻';
  if (level === 'success') return '✓';
  return source === 'provider' ? '◆' : '◎';
}

function safeJson(value: any) {
  try {
    return JSON.stringify(value, null, 2);
  } catch {
    return String(value);
  }
}

function isMidtransOrder(order: Order) {
  return String(order.paymentProvider || '').toLowerCase() === 'midtrans' || String(order.paymentMethod || '').toLowerCase().includes('midtrans');
}

function isFinalOrder(order: Order) {
  return ['success', 'failed', 'canceled', 'cancelled'].includes(String(order.orderStatus || '').toLowerCase());
}

function displayMidtransStatus(value?: string) {
  const status = String(value || '').toLowerCase();
  if (!status) return '';
  if (status === 'snap_created' || status === 'payment_created') return 'payment_created';
  return status;
}

function formatPaymentName(method: PaymentMethod) {
  return String(method.provider || '').toLowerCase() === 'midtrans' || String(method.id || '').toLowerCase().includes('midtrans') ? 'Midtrans' : method.name;
}

function MaintenanceView({
  site,
  setSite,
  saveSite,
  expire,
  check
}: {
  site: any;
  setSite: (value: any) => void;
  saveSite: () => void;
  expire: () => void;
  check: () => void;
}) {
  const update = (key: string, value: any) => setSite({ ...site, [key]: value });

  return (
    <div className="panel">
      <div className="cardTop">
        <div>
          <h2>Maintenance Web & Sistem</h2>
          <p>Kontrol mode maintenance untuk Store/Web dan jalankan perawatan rutin sistem.</p>
        </div>
        <Badge value={site.maintenanceMode ? 'maintenance-on' : 'maintenance-off'} />
      </div>

      <div className="maintenanceModePanel">
        <div className="cardTop">
          <div>
            <h3>Web Maintenance Mode</h3>
            <p>Jika aktif, Storefront hanya menampilkan halaman Maintenance modern. Admin dan API tetap berjalan.</p>
          </div>
          <label className="switchLike">
            <input
              type="checkbox"
              checked={Boolean(site.maintenanceMode)}
              onChange={(e) => update('maintenanceMode', e.target.checked)}
            />
            <span>{site.maintenanceMode ? 'ON' : 'OFF'}</span>
          </label>
        </div>

        <div className="formGrid">
          <label>
            Judul Maintenance
            <input
              value={site.maintenanceTitle || 'Web Sedang Maintenance'}
              onChange={(e) => update('maintenanceTitle', e.target.value)}
            />
          </label>

          <label>
            Pesan Maintenance
            <input
              value={site.maintenanceMessage || 'Kami sedang melakukan perawatan sistem agar layanan PPOB lebih stabil dan aman.'}
              onChange={(e) => update('maintenanceMessage', e.target.value)}
            />
          </label>

          <label>
            Estimasi / Info
            <input
              value={site.maintenanceEta || 'Silakan cek kembali beberapa saat lagi.'}
              onChange={(e) => update('maintenanceEta', e.target.value)}
            />
          </label>

          <label>
            WhatsApp Admin
            <input
              value={site.maintenanceWhatsapp || site.whatsappNumber || ''}
              onChange={(e) => update('maintenanceWhatsapp', e.target.value)}
              placeholder="628xxxx"
            />
          </label>
        </div>

        <button className="btn primary" onClick={saveSite}>Simpan Maintenance Mode</button>
      </div>

      <div className="maintenanceGrid">
        <button className="quickCard yellow" onClick={expire}>
          <span>⏱</span>
          <b>Expire Pending</b>
          <small>Batalkan order pending yang sudah melewati batas waktu.</small>
        </button>

        <button className="quickCard pink" onClick={check}>
          <span>↻</span>
          <b>Check Processing Order</b>
          <small>Cek ulang order processing / need_check agar status lebih update.</small>
        </button>
      </div>

      <div className="maintenanceNote">
        <b>Fungsi Maintenance</b>
        <p>
          Maintenance dipakai untuk mengarahkan Store/Web ke halaman perawatan modern,
          sekaligus menjalankan perawatan rutin seperti expire pending dan check processing.
        </p>
      </div>
    </div>
  );
}

function Stat({ title, value, icon, tone }: { title: string; value: any; icon: string; tone: string }) {
  return <div className={`statCard tone-${tone}`}><div className="statIcon">{icon}</div><span>{title}</span><b>{value}</b></div>;
}

function Badge({ value }: { value: string }) {
  return <span className={`badge ${String(value).toLowerCase()}`}>{value}</span>;
}
