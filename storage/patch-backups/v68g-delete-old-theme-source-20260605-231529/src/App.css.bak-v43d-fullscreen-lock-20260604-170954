
.qrisBoxReal {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  padding: 16px;
}

.qrisImage {
  width: 100%;
  max-width: 260px;
  height: auto;
  display: block;
  margin: 0 auto;
  border: 3px solid #111827;
  border-radius: 16px;
  background: #fff;
  padding: 12px;
}


.erlkimTestingBadge {
  position: fixed;
  left: 16px;
  right: 16px;
  bottom: 16px;
  z-index: 9999;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 4px 12px;
  align-items: center;
  max-width: 760px;
  margin: 0 auto;
  padding: 12px 14px;
  border: 3px solid #111827;
  border-radius: 16px;
  background: #facc15;
  color: #111827;
  box-shadow: 5px 5px 0 #111827;
  font-size: 13px;
}

.erlkimTestingBadge strong {
  font-size: 14px;
  line-height: 1.1;
}

.erlkimTestingBadge span {
  grid-column: 1 / 2;
  opacity: 0.9;
}

.erlkimTestingBadge button {
  grid-column: 2 / 3;
  grid-row: 1 / 3;
  width: 32px;
  height: 32px;
  border: 2px solid #111827;
  border-radius: 10px;
  background: #fff;
  color: #111827;
  font-weight: 900;
  cursor: pointer;
}

@media (max-width: 640px) {
  .erlkimTestingBadge {
    left: 10px;
    right: 10px;
    bottom: 10px;
    font-size: 12px;
  }
}

/* v41 Store Invoice UI polish */
.invoiceStatusGuide {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 14px;
  align-items: center;
  border: 3px solid #111827;
  border-radius: 18px;
  padding: 14px;
  margin: 14px 0;
  background: #fef3c7;
  box-shadow: 4px 4px 0 #111827;
}

.invoiceStatusGuide.success,
.invoiceStatusGuide.paid.success {
  background: #bbf7d0;
}

.invoiceStatusGuide.processing,
.invoiceStatusGuide.paid.processing {
  background: #bfdbfe;
}

.invoiceStatusGuide.failed,
.invoiceStatusGuide.canceled,
.invoiceStatusGuide.cancelled {
  background: #fecaca;
}

.invoiceStatusGuide h3 {
  margin: 4px 0;
  font-size: 18px;
}

.invoiceStatusGuide p {
  margin: 0;
  font-size: 13px;
  line-height: 1.45;
}

.invoiceStatusPills {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8px;
}

.qrisInstructionBox {
  display: grid;
  gap: 6px;
  border: 3px solid #111827;
  border-radius: 16px;
  background: #fef3c7;
  padding: 12px;
  box-shadow: 3px 3px 0 #111827;
}

.qrisInstructionBox p {
  margin: 0;
  font-size: 13px;
  line-height: 1.45;
}

.qrisInstructionBox small {
  font-weight: 900;
}

.resultCard.successResult {
  border: 3px solid #111827;
  border-radius: 18px;
  background: #bbf7d0;
  box-shadow: 4px 4px 0 #111827;
}

.resultCard.successResult code {
  display: block;
  padding: 12px;
  border: 2px solid #111827;
  border-radius: 12px;
  background: #ffffff;
  word-break: break-word;
  font-size: 16px;
  font-weight: 900;
}

.invoicePaymentPanel .manualPayBox {
  display: grid;
  gap: 12px;
}

.invoicePaymentPanel .qrisBoxReal,
.invoicePaymentPanel .qrisBox {
  max-width: 292px;
  margin: 0 auto;
}

@media (max-width: 720px) {
  .invoiceStatusGuide {
    grid-template-columns: 1fr;
  }

  .invoiceStatusPills {
    justify-content: flex-start;
  }

  .invoicePaymentPanel .qrisBoxReal,
  .invoicePaymentPanel .qrisBox {
    max-width: 100%;
  }
}

/* v42 Store checkout/product polish */
.erlkimStoreCheckoutPolish {
  width: min(1180px, calc(100% - 24px));
  margin: 14px auto;
  border: 3px solid #111827;
  border-radius: 18px;
  background: #fef3c7;
  box-shadow: 5px 5px 0 #111827;
  padding: 14px;
  color: #111827;
}

.erlkimStoreCheckoutPolish strong {
  display: block;
  font-size: 16px;
  margin-bottom: 4px;
}

.erlkimStoreCheckoutPolish p {
  margin: 0;
  font-size: 13px;
  line-height: 1.45;
}

.erlkimStoreCheckoutTips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 10px;
}

.erlkimStoreCheckoutTips span {
  border: 2px solid #111827;
  border-radius: 999px;
  background: #fff;
  padding: 6px 9px;
  box-shadow: 2px 2px 0 #111827;
  font-size: 12px;
  font-weight: 900;
}

@media (max-width: 640px) {
  .erlkimStoreCheckoutPolish {
    width: calc(100% - 20px);
    margin: 10px auto;
    padding: 12px;
  }

  .erlkimStoreCheckoutTips {
    display: grid;
  }
}

/* v43c Modern Web Maintenance Mode */
.erlkimMaintenanceLocked,
.erlkimMaintenanceLocked body {
  overflow: hidden;
}

.erlkimWebMaintenanceMode {
  position: fixed;
  inset: 0;
  z-index: 2147483000;
  display: grid;
  place-items: center;
  padding: 22px;
  background:
    radial-gradient(circle at top left, #facc15 0 18%, transparent 19%),
    radial-gradient(circle at bottom right, #93c5fd 0 20%, transparent 21%),
    #fff7ed;
  color: #111827;
}

.erlkimMaintenanceBgShape {
  position: absolute;
  border: 4px solid #111827;
  box-shadow: 8px 8px 0 #111827;
  opacity: .9;
  pointer-events: none;
}

.erlkimMaintenanceBgShape.one {
  width: 120px;
  height: 120px;
  border-radius: 30px;
  background: #fb7185;
  top: 8%;
  right: 10%;
  transform: rotate(12deg);
}

.erlkimMaintenanceBgShape.two {
  width: 90px;
  height: 90px;
  border-radius: 999px;
  background: #22c55e;
  bottom: 10%;
  left: 8%;
}

.erlkimMaintenanceCard {
  position: relative;
  width: min(620px, 100%);
  display: grid;
  gap: 14px;
  border: 5px solid #111827;
  border-radius: 28px;
  background: rgba(255, 255, 255, .94);
  padding: clamp(22px, 5vw, 42px);
  box-shadow: 12px 12px 0 #111827;
  text-align: center;
}

.erlkimMaintenanceLogo {
  width: 76px;
  height: 76px;
  margin: 0 auto;
  display: grid;
  place-items: center;
  border: 4px solid #111827;
  border-radius: 22px;
  background: #facc15;
  box-shadow: 5px 5px 0 #111827;
  font-size: 26px;
  font-weight: 1000;
}

.erlkimMaintenanceEyebrow {
  width: fit-content;
  margin: 0 auto;
  border: 3px solid #111827;
  border-radius: 999px;
  background: #111827;
  color: #fff;
  padding: 6px 12px;
  font-size: 12px;
  font-weight: 900;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.erlkimMaintenanceCard h1 {
  margin: 0;
  font-size: clamp(30px, 7vw, 56px);
  line-height: .95;
  letter-spacing: -.04em;
}

.erlkimMaintenanceCard p {
  margin: 0;
  font-size: clamp(15px, 2.5vw, 18px);
  line-height: 1.55;
}

.erlkimMaintenanceInfo {
  border: 3px solid #111827;
  border-radius: 18px;
  background: #fef3c7;
  padding: 12px;
  box-shadow: 4px 4px 0 #111827;
  display: grid;
  gap: 4px;
}

.erlkimMaintenanceInfo span {
  font-size: 12px;
  font-weight: 900;
  opacity: .7;
  text-transform: uppercase;
}

.erlkimMaintenanceInfo b {
  font-size: 16px;
}

.erlkimMaintenanceActions {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 10px;
}

.erlkimMaintenanceActions button,
.erlkimMaintenanceActions a {
  border: 3px solid #111827;
  border-radius: 14px;
  background: #111827;
  color: #fff;
  padding: 12px 16px;
  box-shadow: 4px 4px 0 #111827;
  font-weight: 900;
  text-decoration: none;
  cursor: pointer;
}

.erlkimMaintenanceActions a {
  background: #22c55e;
  color: #052e16;
}

.erlkimMaintenanceCard small {
  opacity: .72;
  font-weight: 800;
}

@media (max-width: 640px) {
  .erlkimWebMaintenanceMode {
    padding: 14px;
  }

  .erlkimMaintenanceCard {
    border-width: 4px;
    border-radius: 22px;
    box-shadow: 7px 7px 0 #111827;
  }

  .erlkimMaintenanceBgShape {
    display: none;
  }

  .erlkimMaintenanceActions {
    display: grid;
  }
}
