function product(id: string, categoryId: string, categorySlug: string, type: 'prepaid' | 'postpaid', brand: string, name: string, sku: string, providerPrice: number, sellingPrice: number, popular: boolean, flashsale: boolean) {
  return {
    id,
    provider: 'digiflazz',
    providerProductId: sku,
    categoryId,
    categorySlug,
    type,
    brand,
    name,
    buyerSkuCode: sku,
    description: `${name} via Digiflazz`,
    providerPrice,
    sellingPrice,
    margin: Math.max(0, sellingPrice - providerPrice),
    buyerProductStatus: true,
    sellerProductStatus: true,
    isActive: true,
    isPopular: popular,
    isFlashsale: flashsale,
    updatedAt: nowIso()
  };
}
