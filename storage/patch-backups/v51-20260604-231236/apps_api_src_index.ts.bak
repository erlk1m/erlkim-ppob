  if (!product) return res.status(404).json({ ok: false, message: 'Produk tidak ditemukan' });
  const allowed = ['isActive', 'isPopular', 'isFlashsale', 'sellingPrice', 'margin', 'categoryId', 'categorySlug', 'description'];
  for (const key of allowed) if (key in req.body) product[key] = req.body[key];
  product.updatedAt = nowIso();
  store.save();
  res.json(ok(product));
});

