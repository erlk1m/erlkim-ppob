const API_BASE = ((import.meta as any).env?.VITE_API_URL || 'https://api.erlkim.web.id/api').replace(/\/+$/, '');

type PublicSettings = {
  environmentBadgeEnabled?: boolean | string;
  environmentBadgeText?: string;
  environmentBadgeDescription?: string;
  environmentBadgeVariant?: string;
  environmentBadgeShowOnInvoice?: boolean | string;
};

function boolValue(value: unknown): boolean {
  if (typeof value === 'boolean') return value;
  if (typeof value === 'string') return ['true', '1', 'yes', 'on'].includes(value.toLowerCase());
  return false;
}

function isInvoicePage(): boolean {
  return /\/invoice\//.test(window.location.pathname);
}

function mountTestingModeBadge(settings: PublicSettings) {
  if (!boolValue(settings.environmentBadgeEnabled)) return;

  const showOnInvoice = settings.environmentBadgeShowOnInvoice !== false && settings.environmentBadgeShowOnInvoice !== 'false';
  if (isInvoicePage() && !showOnInvoice) return;

  const existing = document.getElementById('erlkim-testing-mode-badge');
  if (existing) existing.remove();

  const wrap = document.createElement('div');
  wrap.id = 'erlkim-testing-mode-badge';
  wrap.className = `erlkimTestingBadge erlkimTestingBadge-${settings.environmentBadgeVariant || 'warning'}`;

  const title = document.createElement('strong');
  title.textContent = settings.environmentBadgeText || 'Development Testing Mode';

  const desc = document.createElement('span');
  desc.textContent = settings.environmentBadgeDescription || 'Mode testing Digiflazz aktif. Gunakan nomor test-case untuk simulasi transaksi.';

  const close = document.createElement('button');
  close.type = 'button';
  close.setAttribute('aria-label', 'Tutup badge');
  close.textContent = '×';
  close.onclick = () => wrap.remove();

  wrap.appendChild(title);
  wrap.appendChild(desc);
  wrap.appendChild(close);
  document.body.appendChild(wrap);
}

async function initTestingModeBadge() {
  try {
    const res = await fetch(`${API_BASE}/settings/public`, { credentials: 'omit' });
    const json = await res.json();
    if (!json?.ok) return;
    mountTestingModeBadge(json.data || {});
  } catch {
    // Badge is non-critical.
  }
}

if (typeof window !== 'undefined') {
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTestingModeBadge, { once: true });
  } else {
    initTestingModeBadge();
  }
}
